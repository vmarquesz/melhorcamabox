---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return !data.draft;
  });
  
  // Get all unique authors
  const authors = [...new Set(posts.flatMap(post => post.data.authors || []))];
  const authorEntries = await getCollection('authors');
  
  return authors.flatMap(author => {
    const authorSlug = author.toLowerCase();
    
    // Filter posts by author
    const authorPosts = posts.filter(post => 
      post.data.authors && post.data.authors.includes(author)
    ).sort((a, b) => {
      return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
    });
    
    // Find author details
    const authorDetails = authorEntries.find(entry => entry.slug.toLowerCase() === authorSlug || entry.data.title.toLowerCase() === authorSlug);
    const authorName = authorDetails ? authorDetails.data.title : author.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()).join(' ');
    
    // Generate pages for this author
    const totalPages = Math.ceil(authorPosts.length / siteConfig.postsPerPage);
    
    return Array.from({ length: totalPages }).map((_, i) => {
      const page = i + 1;
      // Skip page 1 as it's handled by the index.astro
      if (page === 1) return null;
      
      return {
        params: { 
          author: authorSlug,
          page: page.toString()
        },
        props: { 
          authorSlug,
          authorName,
          posts: authorPosts,
          page,
          count: authorPosts.length
        }
      };
    }).filter(Boolean); // Remove null entries
  });
}

const { authorSlug, authorName, posts, page, count } = Astro.props;
const currentPage = parseInt(page);
const basePath = `/authors/${authorSlug}`;

// Get pagination data
const { startIndex, endIndex, prevUrl, nextUrl, totalPages } = getPagination({ 
  page: currentPage, 
  totalPosts: count, 
  basePath 
});

// Get posts for the current page
const paginatedPosts = posts.slice(startIndex, endIndex);

// Set noindex based on site config
const noindex = siteConfig.noindex.authors;
---

<Layout 
  title={`Artigos de ${authorName} - Página ${currentPage} - ${siteConfig.title}`}
  description={`Veja os posts escritos por ${authorName} - Página ${currentPage}`}
  noindex={noindex}
>
  <div class="w-full py-8">
    <header class="mb-10">
      <h1 class="text-4xl md:text-6xl font-extrabold font-headline tracking-tight text-on-surface mb-6">
        Autor: {authorName}
      </h1>
      <p class="text-xl text-on-surface-variant font-body mb-2">
        Página {currentPage} de {totalPages} - {count} {count === 1 ? 'Artigo disponível' : 'Artigos disponíveis'} deste autor
      </p>
    </header>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {paginatedPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
    
    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
      basePath={basePath}
    />
  </div>
</Layout>
