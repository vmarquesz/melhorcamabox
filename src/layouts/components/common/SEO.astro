---
import { siteConfig } from '@config/site';
import social from '@config/social.json';
import config from '@config/config.json';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  noindex?: boolean;
  canonical?: string;
  publishDate?: Date;
  modifiedDate?: Date;
  author?: {
    name: string;
    url?: string;
  };
  tags?: string[];
  categories?: string[];
  breadcrumbs?: Array<{name: string; url: string}>;
  schemaType?: 'WebSite' | 'WebPage' | 'Article' | 'CollectionPage' | 'ProfilePage' | 'AboutPage' | 'ContactPage' | 'SearchResultsPage';
  authorProfile?: {
    name: string;
    description?: string;
    image?: string;
    url?: string;
    sameAs?: string[];
  };
  video?: {
    src: string;
    name?: string;
    description?: string;
    thumbnailUrl?: string;
    uploadDate?: Date;
    duration?: string; // ISO 8601 format
  };
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = siteConfig.ogImage,
  article = false,
  noindex = false,
  canonical = Astro.url.pathname,
  publishDate,
  modifiedDate,
  author,
  tags,
  categories,
  breadcrumbs,
  schemaType,
  authorProfile,
  video
} = Astro.props;

const path = Astro.url.pathname;
const normalizedPath = path.toLowerCase();
const pathSegments = normalizedPath.split('/').filter(Boolean);
const siteUrl = Astro.site ? Astro.site.toString() : '';
const absoluteSite = siteUrl.replace(/\/$/, '');
const socialProfiles = Object.values(social).filter((value) => typeof value === 'string' && /^https?:\/\//.test(value));
const contactInfo = config.contactinfo || {};

const isCategories = normalizedPath.includes('/categorias/');
const isAuthors = normalizedPath.includes('/authors/');
const isSearch = normalizedPath.includes('/search');
const isPagination = normalizedPath.includes('/page/');

let shouldNoindex = noindex;
if (
  (isCategories && siteConfig.noindex.categories) ||
  (isAuthors && siteConfig.noindex.authors) ||
  isSearch ||
  isPagination
) {
  shouldNoindex = true;
}

const publishISODate = publishDate ? new Date(publishDate).toISOString() : null;
const modifiedISODate = modifiedDate ? new Date(modifiedDate).toISOString() : publishISODate;

const safeUrl = (path, base) => {
  const baseToUse = base ? base.toString() : siteUrl;
  try {
    return new URL(path, baseToUse).toString();
  } catch (e) {
    return `${baseToUse.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;
  }
};

let canonicalURL;
try {
  canonicalURL = new URL(canonical, siteUrl).toString();
} catch (e) {
  canonicalURL = `${absoluteSite}/${canonical.replace(/^\//, '')}`;
}

const resolvedSchemaType = (() => {
  if (schemaType) return schemaType;
  if (article) return 'Article';
  if (normalizedPath === '/') return 'WebSite';
  if (normalizedPath === '/sobre-nos/' || normalizedPath === '/sobre-nos') return 'AboutPage';
  if (normalizedPath === '/contato/' || normalizedPath === '/contato') return 'ContactPage';
  if (normalizedPath === '/search/' || normalizedPath === '/search') return 'SearchResultsPage';
  if (normalizedPath === '/authors/' || normalizedPath === '/authors') return 'CollectionPage';
  if (normalizedPath.startsWith('/authors/')) {
    return pathSegments.length === 2 ? 'ProfilePage' : 'CollectionPage';
  }
  if (
    normalizedPath.startsWith('/blog') ||
    normalizedPath.startsWith('/categorias') ||
    normalizedPath.startsWith('/series')
  ) {
    return 'CollectionPage';
  }
  return 'WebPage';
})();

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": siteConfig.title,
  "url": absoluteSite,
  "logo": safeUrl(image, siteUrl),
  ...(socialProfiles.length ? { "sameAs": socialProfiles } : {}),
  ...((contactInfo.email || contactInfo.phone) ? {
    "contactPoint": [{
      "@type": "ContactPoint",
      ...(contactInfo.email ? { "email": contactInfo.email } : {}),
      ...(contactInfo.phone ? { "telephone": contactInfo.phone } : {}),
      "contactType": "customer support"
    }]
  } : {})
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteConfig.title,
  "url": absoluteSite,
  "description": siteConfig.description,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${absoluteSite}/search/?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};

const breadcrumbsSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    "item": safeUrl(item.url, siteUrl)
  }))
} : null;

const videoSchema = video ? {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": video.name || title,
  "description": video.description || description,
  "thumbnailUrl": safeUrl(video.thumbnailUrl || image, siteUrl),
  "uploadDate": video.uploadDate ? new Date(video.uploadDate).toISOString() : publishISODate,
  "duration": video.duration || "PT0M0S",
  "contentUrl": video.src,
  "embedUrl": video.src
} : null;

const articleSchema = article && publishISODate ? {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "image": safeUrl(image, siteUrl),
    "url": canonicalURL,
    "datePublished": publishISODate,
    "dateModified": modifiedISODate || publishISODate,
    ...(author ? {
      "author": {
      "@type": "Person",
      "name": author.name,
      "url": author.url
    }} : {}),
    ...(categories?.length ? { "articleSection": categories.join(', ') } : {}),
    "publisher": {
      "@type": "Organization",
      "name": siteConfig.title,
      "logo": {
        "@type": "ImageObject",
        "url": safeUrl(image, siteUrl)
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonicalURL
    },
    "keywords": tags?.join(", ") || ""
} : null;

const pageSchemaType = resolvedSchemaType === 'SearchResultsPage' ? 'WebPage' : resolvedSchemaType;
const pageSchema = ['WebPage', 'CollectionPage', 'AboutPage', 'ContactPage', 'SearchResultsPage'].includes(resolvedSchemaType) ? {
  "@context": "https://schema.org",
  "@type": pageSchemaType,
  "name": title,
  "description": description,
  "url": canonicalURL
} : null;

const profileSchema = resolvedSchemaType === 'ProfilePage' ? {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "name": title,
  "description": description,
  "url": canonicalURL,
  "mainEntity": {
    "@type": "Person",
    "name": authorProfile?.name || title,
    ...(authorProfile?.description ? { "description": authorProfile.description } : {}),
    ...(authorProfile?.image ? { "image": safeUrl(authorProfile.image, siteUrl) } : {}),
    ...(authorProfile?.url ? { "url": authorProfile.url } : {}),
    ...(authorProfile?.sameAs?.length ? { "sameAs": authorProfile.sameAs } : {})
  }
} : null;

const primarySchema =
  articleSchema ||
  profileSchema ||
  (resolvedSchemaType === 'WebSite' ? websiteSchema : pageSchema || websiteSchema);

const schemas = [primarySchema, organizationSchema].filter(Boolean);
---

<!-- SEO Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={article ? "article" : "website"} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={(() => {
  try {
    return new URL(image, siteUrl).toString();
  } catch (e) {
    return `${absoluteSite}/${image.replace(/^\//, '')}`;
  }
})()} />

{article && publishISODate && (
  <meta property="article:published_time" content={publishISODate} />
)}

{article && modifiedISODate && (
  <meta property="article:modified_time" content={modifiedISODate} />
)}

{article && tags && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={(() => {
  try {
    return new URL(image, siteUrl).toString();
  } catch (e) {
    return `${absoluteSite}/${image.replace(/^\//, '')}`;
  }
})()} />

<!-- Robots Meta -->
{shouldNoindex ? (
  <meta name="robots" content="noindex, nofollow" />
) : (
  <meta name="robots" content="index, follow" />
)}

<!-- RSS Feed autodiscovery -->
<link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} RSS Feed`} href="/rss.xml" />
<link rel="feed" type="application/rss+xml" title={`${siteConfig.title} RSS Feed`} href="/rss.xml" /> 

<!-- Schema.org JSON-LD -->
{schemas.map((item) => (
  <script type="application/ld+json" set:html={JSON.stringify(item)} />
))}

<!-- BreadcrumbList Schema (if breadcrumbs are provided) -->
{breadcrumbsSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsSchema)} />
)}

<!-- VideoObject Schema (if video is provided) -->
{videoSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />
)}
