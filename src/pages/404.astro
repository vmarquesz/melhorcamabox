---
import Layout from '@layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="404 - Página Não Encontrada | Guia Robô Aspirador" description="A página que você está procurando não existe.">
  <div class="w-full py-16 flex flex-col items-center justify-center text-center px-4">
    <div class="max-w-md">
      <Icon name="mdi:alert-circle-outline" class="w-24 h-24 text-primary dark:text-blue-400 mx-auto mb-6" />
      
      <h1 class="text-4xl md:text-6xl font-black font-headline text-on-surface dark:text-slate-100 mb-4 tracking-tighter">
        404
      </h1>
      
      <h2 class="text-2xl md:text-3xl font-bold font-headline text-on-surface dark:text-slate-200 mb-6 tracking-tight">
        Página Não Encontrada
      </h2>
      
      <p class="text-lg text-on-surface-variant dark:text-slate-400 mb-8 font-body">
        A página que você está procurando não existe ou foi movida.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/" 
          class="px-8 py-4 hero-gradient text-on-primary rounded-xl font-bold transition-all active:scale-95 flex items-center justify-center ink-shadow"
        >
          <Icon name="mdi:home" class="w-5 h-5 mr-2" />
          Voltar ao Início
        </a>
        
        <a 
          href="/blog/" 
          class="px-8 py-4 bg-surface-container-low text-primary rounded-xl font-bold transition-all hover:bg-surface-container-high flex items-center justify-center"
        >
          <Icon name="mdi:book-open-page-variant" class="w-5 h-5 mr-2" />
          Ver Blog
        </a>
      </div>
    </div>
  </div>
</Layout>
