---
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { Icon } from 'astro-icon/components';
import contatoHeroImg from '../assets/images/contato-hero-stitch.webp';

const faqItems = [
  {
    question: 'Vocês vendem Air Fryers?',
    answer: 'Não, somos um portal independente de análises. Apenas testamos e recomendamos os melhores modelos disponíveis no mercado.',
  },
  {
    question: 'Como sugerir um modelo?',
    answer: 'Utilize o formulário acima selecionando "Sugestão de Review". Nossa equipe de teste avalia novos lançamentos mensalmente.',
  },
  {
    question: 'As reviews são pagas?',
    answer: 'Nossa política editorial proíbe avaliações pagas. Mantemos nossa independência técnica para garantir a melhor orientação ao consumidor.',
  },
];
---

<Layout
  title={`Contato | ${siteConfig.title}`}
  description="Entre em contato com a equipe do Guia de Air Fryer. Nossos especialistas estão prontos para ajudar você a encontrar o air fryer perfeito."
  wideContent={true}
  noTopPadding={true}
>
  <!-- Hero Section -->
  <section class="relative h-64 md:h-80 w-full overflow-hidden flex items-center justify-center">
    <div class="absolute inset-0 bg-inverse-surface/40 z-10"></div>
    <Image
      src={contatoHeroImg}
      alt="Contato Guia de Air Fryer"
      width={2560}
      height={400}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="relative z-20 text-center px-gutter">
      <h1 class="font-headline text-4xl md:text-5xl font-bold text-white mb-4">Fale Conosco</h1>
      <p class="font-body text-lg md:text-xl text-white/90 max-w-xl mx-auto">Tire suas dúvidas técnicas, sugira novos testes ou entre em contato comercial.</p>
    </div>
  </section>

  <!-- Main Content Grid -->
  <section class="max-w-container-max mx-auto px-gutter py-16 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Contact Info & Socials -->
      <div class="lg:col-span-4 space-y-8">
        <div class="bg-surface-container-low p-6 rounded-lg border border-outline-variant">
          <h3 class="font-headline text-xl font-semibold text-primary mb-6">Canais Diretos</h3>
          <div class="space-y-6">
            <div class="flex items-start gap-3">
              <Icon name="material-symbols:mail" class="w-5 h-5 text-primary" />
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant">E-mail Comercial</p>
                <p class="font-body font-bold">contato@guiadeairfryer.com.br</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="material-symbols:forum" class="w-5 h-5 text-primary" />
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Suporte ao Leitor</p>
                <p class="font-body font-bold">suporte@guiadeairfryer.com.br</p>
              </div>
            </div>
          </div>
        </div>
        <div class="space-y-4">
          <h3 class="font-headline text-xl font-semibold text-on-surface">Redes Sociais</h3>
          <div class="flex gap-4">
            <a class="w-12 h-12 flex items-center justify-center rounded-full bg-primary-fixed hover:bg-primary-container transition-colors" href="#" aria-label="Instagram">
              <Icon name="mdi:instagram" class="w-5 h-5 text-on-primary-fixed" />
            </a>
            <a class="w-12 h-12 flex items-center justify-center rounded-full bg-primary-fixed hover:bg-primary-container transition-colors" href="#" aria-label="YouTube">
              <Icon name="mdi:youtube" class="w-5 h-5 text-on-primary-fixed" />
            </a>
            <a class="w-12 h-12 flex items-center justify-center rounded-full bg-primary-fixed hover:bg-primary-container transition-colors" href="#" aria-label="Facebook">
              <Icon name="mdi:facebook" class="w-5 h-5 text-on-primary-fixed" />
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="lg:col-span-8 bg-surface-container-lowest p-8 rounded-lg border border-outline-variant shadow-sm">
        <h2 class="font-headline text-2xl md:text-3xl font-bold text-on-surface mb-8">Envie sua Mensagem</h2>
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
              <label class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Nome</label>
              <input class="bg-surface-bright border border-outline-variant rounded-lg p-3 font-body focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all" placeholder="Seu nome completo" type="text" required />
            </div>
            <div class="flex flex-col gap-2">
              <label class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant">E-mail</label>
              <input class="bg-surface-bright border border-outline-variant rounded-lg p-3 font-body focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all" placeholder="seu@email.com" type="email" required />
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Assunto</label>
            <select class="bg-surface-bright border border-outline-variant rounded-lg p-3 font-body focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all appearance-none" required>
              <option value="">Selecione um assunto...</option>
              <option value="duvida">Dúvida Técnica</option>
              <option value="sugestao">Sugestão de Review</option>
              <option value="parceria">Parceria Comercial</option>
              <option value="erro">Erro no Site</option>
              <option value="outros">Outros</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Mensagem</label>
            <textarea class="bg-surface-bright border border-outline-variant rounded-lg p-3 font-body focus:border-primary focus:ring-2 focus:ring-primary/10 outline-none transition-all resize-none" placeholder="Como podemos ajudar você hoje?" rows="5" required></textarea>
          </div>
          <button class="bg-primary text-on-primary font-bold py-4 px-8 rounded-lg hover:bg-secondary transition-all active:scale-95 flex items-center justify-center gap-2 w-full md:w-auto" type="submit">
            <span>Enviar Mensagem</span>
            <Icon name="material-symbols:send" class="w-5 h-5" />
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="bg-surface-container-high py-16 md:py-24">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-12">
        <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-surface">FAQ Rápido</h2>
        <p class="font-body text-on-surface-variant mt-4">Talvez sua dúvida já tenha uma resposta rápida abaixo.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {faqItems.map((item) => (
          <div class="bg-surface p-6 rounded-lg border-l-4 border-primary">
            <h4 class="font-headline text-lg font-semibold text-on-surface mb-3">{item.question}</h4>
            <p class="font-body text-on-surface-variant">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
