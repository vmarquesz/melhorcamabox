---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';
import { featuredCategories, slugify } from '@config/categories';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    return !data.draft;
  });
  
  const normalizeCategory = (value: string) => slugify(value);
  const featuredMap = new Map(featuredCategories.map((item) => [item.slug, item]));
  
  // Get all unique categories from posts and featured
  const postCategories = [...new Set(posts.flatMap(post => post.data.categories || []))];
  const allCategories = [...new Set([...postCategories, ...featuredCategories.map(c => c.name)])];
  
  return allCategories.flatMap(category => {
    const categorySlug = normalizeCategory(category);
    
    // Filter posts by category
    const categoryPosts = posts.filter(post => 
      (post.data.categories || []).some(c => normalizeCategory(c) === categorySlug)
    ).sort((a, b) => {
      return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
    });
    
    const categoryName = featuredMap.get(categorySlug)?.name ||
      categorySlug.split('-').map((word) => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

    // Generate pages for this category
    const totalPages = Math.ceil(categoryPosts.length / siteConfig.postsPerPage);
    
    return Array.from({ length: totalPages }).map((_, i) => {
      const page = i + 1;
      // Skip page 1 as it's handled by the index.astro
      if (page === 1) return null;
      
      return {
        params: { 
          category: categorySlug,
          page: page.toString()
        },
        props: { 
          categorySlug,
          categoryName,
          posts: categoryPosts,
          page,
          count: categoryPosts.length
        }
      };
    }).filter(Boolean); // Remove null entries
  });
}

const { categorySlug, categoryName, posts, page, count } = Astro.props;
const currentPage = parseInt(page);
const basePath = `/${categorySlug}`;

// Get pagination data
const { startIndex, endIndex, prevUrl, nextUrl, totalPages } = getPagination({ 
  page: currentPage, 
  totalPosts: count, 
  basePath 
});

// Get posts for the current page
const paginatedPosts = posts.slice(startIndex, endIndex);

// Set noindex based on site config
const noindex = siteConfig.noindex.categories;
---

<Layout 
  title={`${categoryName} - Página ${currentPage} - ${siteConfig.title}`}
  description={`Veja os posts da categoria ${categoryName} - Página ${currentPage}`}
  noindex={noindex}
>
  <div class="w-full py-8">
    <header class="mb-10">
      <h1 class="text-4xl md:text-6xl font-extrabold font-headline tracking-tight text-on-surface mb-6">
        Categoria: {categoryName}
      </h1>
      <p class="text-xl text-on-surface-variant font-body mb-2">
        Página {currentPage} de {totalPages} - {count} {count === 1 ? 'Análise disponível' : 'Análises disponíveis'} nesta categoria
      </p>
    </header>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {paginatedPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
    
    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
      basePath={basePath}
    />
  </div>
</Layout>

