---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@config/site';

// Get all blog posts
const posts = await getCollection('posts', ({ data }) => {
  return !data.draft;
});

// Get all unique authors and count posts for each
const authorEntriesList = await getCollection('authors');
const authors = [...new Set(posts.flatMap(post => post.data.authors || []))];
const authorCounts = authors.map(author => {
  const count = posts.filter(post => 
    post.data.authors && post.data.authors.includes(author)
  ).length;
  
  const authorDetails = authorEntriesList.find(entry => entry.id === author || entry.slug === author);
  
  return {
    name: authorDetails ? authorDetails.data.title : author,
    count,
    slug: author.toLowerCase()
  };
}).sort((a, b) => b.count - a.count); // Sort by post count (descending)

// Format author names for display as fallback
const formatAuthorName = (name: string) => {
  return name.split(' ').map(word => 
    word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()
  ).join(' ');
};---

<Layout 
  title={`Autores - ${siteConfig.title}`}
  description="Conheça nossos autores e navegue por seus posts"
>
  <main class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-20">
    <nav class="flex items-center gap-2 text-sm font-medium text-on-surface-variant mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <Icon name="material-symbols:chevron-right" class="w-4 h-4" />
      <span class="text-on-surface-variant/60">Autores</span>
    </nav>

    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim tracking-tight mb-4">
        Autores
      </h1>
      <p class="text-lg text-on-surface-variant dark:text-on-surface-variant max-w-2xl">
        Conheça nossos autores e navegue por seus posts
      </p>
    </header>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {authorCounts.map(({ name, count, slug }) => (
        <a 
          href={`/authors/${slug}/`}
          class="flex items-center justify-between p-6 bg-surface-container-lowest dark:bg-surface-container-high/50 rounded-xl border border-outline-variant/10 dark:border-outline-variant/10 shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] hover:shadow-xl hover:border-primary/20 dark:hover:border-primary-container/40 transition-all"
        >
          <div class="flex items-center">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-primary-container/10 dark:bg-primary-container/20 text-primary dark:text-primary-fixed-dim mr-4">
              <Icon name="mdi:account" class="w-6 h-6" />
            </div>
            <span class="font-semibold text-on-surface dark:text-on-surface">
              {name.includes(' ') ? name : formatAuthorName(name)}
            </span>
          </div>
          <span class="bg-primary-container/10 dark:bg-primary-container/20 text-primary dark:text-primary-fixed-dim text-xs font-semibold px-3 py-1 rounded-full shrink-0">
            {count} {count === 1 ? 'post' : 'posts'}
          </span>
        </a>
      ))}
    </div>
    
    {authorCounts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-on-surface-variant">Nenhum autor encontrado.</p>
      </div>
    )}
  </main>
</Layout>
