---
interface Product {
  title: string;
  image: string;
  link: string;
}

interface Props {
  products: Product[];
}

import { Icon } from 'astro-icon/components';

const { products } = Astro.props;
const safeProducts = Array.isArray(products) && products.length > 0 ? products : [];
---

{safeProducts.length > 0 && (
<section class="summary-list not-prose my-16 space-y-6">
  <div class="flex items-center gap-4 mb-8">
    <div class="w-12 h-12 rounded-2xl bg-primary-container flex items-center justify-center text-on-primary-container shadow-lg">
      <Icon name="material-symbols:assignment-turned-in" class="w-8 h-8" />
    </div>
    <h3 class="font-headline text-3xl font-extrabold text-primary dark:text-primary-fixed-dim tracking-tighter">
      Resumo dos Melhores Modelos
    </h3>
  </div>
  
  <div class="space-y-4">
    {safeProducts.map((item, index) => (
      <div class="flex flex-row items-center gap-2 sm:gap-4 md:gap-8 p-3 sm:p-4 md:p-6 bg-surface-container-lowest dark:bg-surface-container-high/30 rounded-2xl border border-outline-variant/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
        <span class="text-base sm:text-xl md:text-3xl font-black font-headline text-primary-container/30 shrink-0 w-4 sm:w-8 md:w-10 text-center tracking-tighter">
          {index + 1}
        </span>
        
        <a href={item.link} target="_blank" rel="nofollow sponsored" class="w-10 h-10 sm:w-16 sm:h-16 md:w-20 md:h-20 bg-white rounded-xl flex items-center justify-center p-1.5 sm:p-2 shrink-0 shadow-sm hover:shadow-md transition-all">
          <img 
            src={item.image} 
            alt={item.title} 
            width="80"
            height="80"
            class="max-h-full object-contain" 
            loading="lazy"
          />
        </a>
        
        <div class="grow text-left min-w-0">
          <a href={item.link} target="_blank" rel="nofollow sponsored">
            <h4 class="font-headline font-bold text-[13px] sm:text-base md:text-xl text-on-surface hover:text-primary transition-colors line-clamp-2 md:line-clamp-3 leading-tight">
              {item.title}
            </h4>
          </a>
        </div>
        
        <a 
          href={item.link} 
          target="_blank" 
          rel="nofollow sponsored" 
          class="bg-primary text-on-primary px-3 py-2 sm:px-4 sm:py-2.5 md:px-8 md:py-4 rounded-lg md:rounded-xl font-bold font-headline hover:bg-primary-container hover:!text-white transition-all text-[9px] sm:text-[10px] md:text-xs uppercase tracking-widest whitespace-nowrap shrink-0 shadow-sm hover:shadow-xl"
        >
          Ver Preço
        </a>
      </div>
    ))}
  </div>
</section>
)}
