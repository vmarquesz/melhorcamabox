---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';
import { Icon } from 'astro-icon/components';

// Get all blog posts and sort by date (newest first)
const posts = await getCollection('posts', ({ data }) => {
  return !data.draft;
});

// Sort posts by date (newest first)
const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
});

// Get pagination data for first page
const { postsPerPage } = getPagination({ 
  page: 1, 
  totalPosts: sortedPosts.length, 
  basePath: '/blog' 
});

// Get posts for the first page
const paginatedPosts = sortedPosts.slice(0, postsPerPage);
---

<Layout
  title={`Blog - ${siteConfig.title}`}
  description="Explore nossos artigos e reviews mais recentes"
>
  <main class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-20">
    <nav class="flex items-center gap-2 text-sm font-medium text-on-surface-variant mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <Icon name="material-symbols:chevron-right" class="w-4 h-4" />
      <span class="text-on-surface-variant/60">Blog</span>
    </nav>

    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim tracking-tight mb-4">
        Blog
      </h1>
      <p class="text-lg text-on-surface-variant dark:text-on-surface-variant max-w-2xl">
        Guias de compra, reviews e as últimas novidades do mundo das camas box.
      </p>
    </header>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {paginatedPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
    
    <Pagination
      currentPage={1}
      totalPages={Math.ceil(sortedPosts.length / postsPerPage)}
      prevUrl={null}
      nextUrl={sortedPosts.length > postsPerPage ? `/blog/page/2/` : null}
      basePath="/blog"
    />
  </main>
</Layout>
