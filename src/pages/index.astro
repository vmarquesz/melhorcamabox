---
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { featuredCategories } from '@config/categories';
import { Icon } from 'astro-icon/components';
import heroHomeImg from '../assets/images/hero-home.webp';
import guiaCompraImg from '../assets/images/guia-compra-home.webp';

// Get all blog posts and sort by date (newest first)
const posts = await getCollection('posts', ({ data }) => {
  return !data.draft;
});

const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
});

const latestPosts = sortedPosts.slice(0, 3);

// Filter categories for home (exactly 8, excluding 'dicas-e-manutencao')
const homeCategories = featuredCategories.filter(cat => cat.slug !== 'dicas-e-manutencao');

// Generate optimized hero image for preloading
const optimizedHeroImage = await getImage({ src: heroHomeImg, format: 'webp' });
---

<Layout
  title={`${siteConfig.title} | Especialistas em Automação de Limpeza`}
  description={siteConfig.description}
  wideContent={true}
  noTopPadding={true}
  preloadImage={optimizedHeroImage.src}
>
  <main class="pt-24 md:pt-32">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-8 mb-20 lg:mb-32">
      <div class="relative overflow-hidden rounded-2xl bg-surface-container-low dark:bg-surface-container-high min-h-[500px] md:min-h-[600px] flex items-center dark:border dark:border-outline-variant/20">
        <div class="absolute inset-0 z-0">
          <Image 
            class="w-full h-full object-cover opacity-90 dark:opacity-40" 
            src={heroHomeImg} 
            alt="Robô aspirador premium em ambiente minimalista"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/60 to-transparent dark:from-surface-container-lowest dark:via-surface-container-lowest/60"></div>
        </div>
        <div class="relative z-10 w-full max-w-2xl px-8 md:px-16">
          <span class="inline-block px-4 py-1 mb-6 rounded-full bg-primary-container text-on-primary-container dark:bg-indigo-500/20 dark:text-indigo-300 dark:border dark:border-indigo-500/30 text-[10px] font-bold tracking-[0.2em] uppercase">
            Editorial 2026
          </span>
          <h1 class="text-5xl md:text-7xl font-extrabold text-primary dark:text-white mb-6 leading-[1.1] tracking-tight">
            Precisão Técnica para sua Casa
          </h1>
          <p class="text-lg md:text-xl text-on-surface-variant dark:text-slate-300 mb-10 max-w-lg leading-relaxed">
            Analisamos rigorosamente os últimos robôs aspiradores para encontrar o equilíbrio perfeito entre autonomia, poder de sucção e inteligência.
          </p>
          <a href="/blog/" class="inline-block bg-primary dark:bg-indigo-600 text-on-primary dark:text-white px-10 py-5 rounded-lg font-bold text-lg hover:shadow-xl dark:hover:shadow-[0_0_20px_rgba(79,70,229,0.4)] hover:-translate-y-1 transition-all duration-300">
            Ver Ranking Completo
          </a>
        </div>
      </div>
    </section>

    <!-- Categories Section -->
    <section class="max-w-7xl mx-auto px-8 mb-24 lg:mb-40">
      <div class="mb-12 md:mb-16">
        <h2 class="text-3xl md:text-4xl font-headline font-bold text-primary dark:text-primary-fixed-dim tracking-tight">Explore por Tecnologia <span class="text-on-surface-variant italic font-normal text-2xl md:text-3xl block md:inline md:ml-2">e Finalidade</span></h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {homeCategories.map((category) => (
          <a href={`/${category.slug}/`} class="group flex flex-col items-center p-8 md:p-10 rounded-2xl bg-surface-container-lowest dark:bg-surface-container-high/50 hover:bg-surface-container-high transition-all duration-500 shadow-[0px_4px_20px_rgba(13,30,37,0.04)] hover:shadow-xl dark:border dark:border-outline-variant/10">
            <div class="w-16 h-16 rounded-full bg-secondary-container dark:bg-primary-container flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
              <Icon name={category.icon} class="text-primary dark:text-primary-fixed-dim text-3xl" />
            </div>
            <span class="font-headline font-bold text-primary dark:text-primary-fixed-dim tracking-tight text-center text-sm md:text-base">{category.name}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Latest Reviews -->
    <section class="max-w-7xl mx-auto px-8 mb-32 lg:mb-48">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
        <div>
          <h2 class="text-4xl font-bold text-primary dark:text-primary-fixed-dim mb-3 tracking-tight">Últimos Reviews</h2>
          <p class="text-on-surface-variant max-w-md">Testes práticos realizados em ambientes reais para garantir a melhor escolha.</p>
        </div>
        <a class="text-primary dark:text-primary-fixed-dim font-bold flex items-center gap-2 hover:translate-x-2 transition-all" href="/blog/">
          Ver todos <Icon name="material-symbols:arrow-forward" class="w-6 h-6" />
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {latestPosts.map((post) => (
          <article class="bg-surface-container-lowest dark:bg-surface-container-high rounded-2xl overflow-hidden group shadow-[0px_4px_24px_rgba(13,30,37,0.04)] dark:shadow-[0px_4px_24px_rgba(0,0,0,0.3)] hover:shadow-2xl transition-all duration-500 flex flex-col h-full border border-transparent dark:border-outline-variant/20 hover:border-outline-variant/20">
            <a href={`/${post.slug}/`} class="h-64 overflow-hidden relative block">
              {post.data.image && (
                <Image 
                  src={post.data.image} 
                  alt={post.data.title}
                  width={640}
                  height={400}
                  widths={[400, 640, 800]}
                  sizes="(max-width: 768px) 100vw, 33vw"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                />
              )}
              <div class="absolute top-4 right-4 bg-primary/90 backdrop-blur-md text-on-primary px-3 py-1 rounded-lg font-headline font-bold text-xs tracking-wider">
                NOVO
              </div>
            </a>
            <div class="p-8 flex flex-col flex-grow">
              <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-4">
                {post.data.categories?.[0] || 'Uncategorized'}
              </p>
              <h3 class="text-2xl font-bold text-primary dark:text-white mb-4 leading-tight group-hover:text-primary-container dark:group-hover:text-primary transition-colors">
                <a href={`/${post.slug}/`}>{post.data.title}</a>
              </h3>
              <p class="text-on-surface-variant text-sm mb-8 flex-grow leading-relaxed line-clamp-3 italic">
                {post.data.description}
              </p>
              <a href={`/${post.slug}/`} class="w-full py-4 bg-secondary-container dark:bg-surface-container-highest dark:border dark:border-outline-variant/40 text-primary dark:text-on-surface-variant rounded-xl font-bold text-center hover:bg-primary dark:hover:bg-indigo-600 hover:text-on-primary dark:hover:text-white dark:hover:border-indigo-500 transition-all">
                Leia o Review
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Buying Guide section -->
    <section class="bg-surface-container-low dark:bg-surface-container-high/30 py-24 md:py-32 mb-32 overflow-hidden">
      <div class="max-w-7xl mx-auto px-8">
        <div class="flex flex-col lg:flex-row gap-20 items-center">
          <div class="lg:w-1/2">
            <h2 class="text-4xl md:text-5xl font-extrabold text-primary dark:text-primary-fixed-dim mb-10 leading-tight tracking-tighter">
              Como escolher seu primeiro <span class="text-on-surface-variant italic font-normal">robô aspirador?</span>
            </h2>
            <div class="space-y-10">
              <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-white dark:bg-surface-container-high/80 flex items-center justify-center text-primary dark:text-primary-fixed-dim font-bold shadow-sm">1</div>
                <div>
                  <h3 class="text-xl font-bold text-primary dark:text-primary-fixed-dim mb-2">Entenda seu Piso</h3>
                  <p class="text-on-surface-variant leading-relaxed">Tapetes altos exigem maior poder de sucção, enquanto pisos frios se beneficiam de bons sistemas de mop.</p>
                </div>
              </div>
              <div class="flex gap-6">
                <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-white dark:bg-surface-container-high/80 flex items-center justify-center text-primary dark:text-primary-fixed-dim font-bold shadow-sm">2</div>
                <div>
                  <h3 class="text-xl font-bold text-primary dark:text-primary-fixed-dim mb-2">Mapeamento Inteligente</h3>
                  <p class="text-on-surface-variant leading-relaxed">Robôs com LiDAR ou câmeras são mais eficientes e preservam seus móveis de impactos desnecessários.</p>
                </div>
              </div>
            </div>
            <a href="/guias-de-compra/" class="mt-14 inline-flex items-center gap-3 text-primary dark:text-primary-fixed-dim font-bold text-lg hover:gap-5 transition-all group">
              Ver Guia de Compra Completo <Icon name="material-symbols:arrow-forward" class="w-6 h-6 group-hover:translate-x-1 transition-transform" />
            </a>
          </div>
          <div class="lg:w-1/2 relative">
            <div class="rounded-3xl overflow-hidden shadow-2xl transform rotate-1">
              <Image 
                class="w-full h-auto" 
                src={guiaCompraImg} 
                alt="Ambiente moderno para robô aspirador"
              />
            </div>
            <div class="absolute -bottom-8 -left-8 bg-tertiary-fixed dark:bg-primary-container/90 dark:border dark:border-primary/30 dark:backdrop-blur-md p-8 rounded-2xl shadow-2xl max-w-xs transform -rotate-2">
              <Icon name="material-symbols:lightbulb" class="w-9 h-9 text-tertiary dark:text-primary" />
              <p class="text-on-tertiary-fixed dark:text-primary-fixed font-medium leading-relaxed">Dica de Ouro: Prefira modelos com escovas laterais duplas para cantos impecáveis.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter Signup -->
    <section class="max-w-5xl mx-auto px-8 mb-32">
      <div class="bg-primary dark:bg-indigo-950 p-12 md:p-20 rounded-[2.5rem] text-center relative overflow-hidden shadow-2xl dark:border dark:border-indigo-900/50">
        <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-white dark:from-indigo-500 via-transparent to-transparent"></div>
        <h2 class="text-4xl md:text-5xl font-bold text-on-primary dark:text-white mb-6 relative z-10 tracking-tight">Receba Ofertas e Lançamentos</h2>
        <p class="text-on-primary-container dark:text-indigo-200 mb-12 max-w-md mx-auto relative z-10 text-lg opacity-90">
          Assine nossa newsletter e acompanhe a evolução da automação doméstica em primeira mão.
        </p>
        <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto relative z-10" action="/search/" method="get">
          <input 
            class="flex-grow px-8 py-5 rounded-xl bg-white dark:bg-surface-container-high border-none dark:border dark:border-outline-variant/30 focus:ring-2 focus:ring-primary-container dark:focus:ring-indigo-500 text-on-background dark:text-on-surface dark:placeholder-slate-500 text-lg" 
            placeholder="Seu melhor e-mail" 
            type="email"
            required
          />
          <button class="bg-primary-container dark:bg-indigo-600 text-white px-10 py-5 rounded-xl font-bold text-lg hover:bg-white dark:hover:bg-indigo-500 hover:text-primary transition-all shadow-lg dark:shadow-indigo-500/20" type="submit">
            Cadastrar
          </button>
        </form>
      </div>
    </section>
  </main>
</Layout>
