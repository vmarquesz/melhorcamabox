---
import { siteConfig } from "@config/site";
import { Icon } from "astro-icon/components";
import social from "@config/social.json";
---

<footer class="w-full mt-20 bg-surface-container-low dark:bg-surface-container-high/30 border-t border-outline-variant/10">
  <div class="flex flex-col md:flex-row justify-between items-start px-8 py-16 max-w-7xl mx-auto gap-12">
    <!-- Brand Info -->
    <div class="max-w-xs">
      <div class="text-xl font-headline font-bold text-primary dark:text-primary-fixed-dim mb-4">
        {siteConfig.title}
      </div>
      <p class="font-body text-sm text-on-surface leading-relaxed">
        {siteConfig.description}
      </p>
    </div>

    <!-- Navigation Columns -->
    <div class="grid grid-cols-2 gap-12 sm:gap-24">
      <div class="flex flex-col gap-4">
        <span class="text-primary dark:text-primary-fixed-dim font-headline font-bold text-xs uppercase tracking-widest">Páginas</span>
        <a class="text-on-surface-variant hover:text-primary transition-colors text-sm" href="/sobre-nos/">Sobre Nós</a>
        <a class="text-on-surface-variant hover:text-primary transition-colors text-sm" href="/politica-de-privacidade/">Privacidade</a>
        <a class="text-on-surface-variant hover:text-primary transition-colors text-sm" href="/termos-de-uso/">Termos de Uso</a>
      </div>
      <div class="flex flex-col gap-4">
        <span class="text-primary dark:text-primary-fixed-dim font-headline font-bold text-xs uppercase tracking-widest">Suporte</span>
        <a class="text-on-surface-variant hover:text-primary transition-colors text-sm" href="/contato/">Contato</a>
        <a class="text-on-surface-variant hover:text-primary transition-colors text-sm" href="/search/">Buscar</a>
      </div>
    </div>

    <!-- Social & Copyright -->
    <div class="flex flex-col items-start md:items-end gap-8">
      <div class="flex gap-4">
        {social.instagram && (
          <a href={social.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center hover:bg-primary hover:text-white transition-all group" aria-label="Instagram">
             <Icon name="mdi:instagram" class="w-5 h-5 group-hover:scale-110 transition-transform" />
          </a>
        )}
        {social.facebook && (
          <a href={social.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center hover:bg-primary hover:text-white transition-all group" aria-label="Facebook">
             <Icon name="mdi:facebook" class="w-5 h-5 group-hover:scale-110 transition-transform" />
          </a>
        )}
        {social.youtube && (
          <a href={social.youtube} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center hover:bg-primary hover:text-white transition-all group" aria-label="YouTube">
             <Icon name="mdi:youtube" class="w-5 h-5 group-hover:scale-110 transition-transform" />
          </a>
        )}
        {social.twitter && (
          <a href={social.twitter} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center hover:bg-primary hover:text-white transition-all group" aria-label="Twitter">
             <Icon name="mdi:twitter" class="w-5 h-5 group-hover:scale-110 transition-transform" />
          </a>
        )}
      </div>
      <div class="text-left md:text-right space-y-2">
        <p class="font-body text-xs text-on-surface-variant/80 italic max-w-xs">
          Comprando através de nossos links, podemos ganhar uma comissão sem custo adicional para você.
        </p>
        <p class="font-body text-[10px] text-on-surface-variant/80">
          {siteConfig.title} © {new Date().getFullYear()} | Todos os direitos reservados.
        </p>
      </div>
    </div>
  </div>
</footer>
