---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/common/Pagination.astro';
import { getPagination } from '@utils/pagination';
import { siteConfig } from '@config/site';
import { featuredCategories, slugify } from '@config/categories';
import { Icon } from 'astro-icon/components';

export async function getStaticPaths() {
  const normalizeCategory = (value: string) => slugify(value);
  const posts = await getCollection('posts', ({ data }) => {
    return !data.draft;
  });

  const featuredMap = new Map(featuredCategories.map((item) => [item.slug, item]));

  const postCategorySlugs = [
    ...new Set(
      posts.flatMap((post) =>
        (post.data.categories || []).map((category) => normalizeCategory(category))
      )
    ),
  ];

  const allCategorySlugs = [...new Set([...featuredCategories.map((item) => item.slug), ...postCategorySlugs])];

  return allCategorySlugs.map((categorySlug) => {
    const categoryPosts = posts
      .filter((post) => (post.data.categories || []).some((category) => normalizeCategory(category) === categorySlug))
      .sort((a, b) => {
        return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
      });

    const categoryName = featuredMap.get(categorySlug)?.name ||
      categorySlug.split('-').map((word) => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

    return {
      params: { category: categorySlug },
      props: {
        categorySlug,
        categoryName,
        posts: categoryPosts,
        count: categoryPosts.length,
      },
    };
  });
}

const { categorySlug, categoryName, posts, count } = Astro.props;
const basePath = `/${categorySlug}`;

// Get pagination data for first page
const { postsPerPage } = getPagination({
  page: 1,
  totalPosts: count,
  basePath,
});

// Get posts for the first page
const paginatedPosts = posts.slice(0, postsPerPage);

// Set noindex based on site config
const noindex = siteConfig.noindex.categories;
---

<Layout
  title={`${categoryName} - ${siteConfig.title}`}
  description={`Veja todos os posts na categoria ${categoryName}`}
  noindex={noindex}
>
  <main class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-20">
    <nav class="flex items-center gap-2 text-sm font-medium text-on-surface-variant mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <Icon name="material-symbols:chevron-right" class="w-4 h-4" />
      <a href="/blog/" class="hover:text-primary transition-colors">Blog</a>
      <Icon name="material-symbols:chevron-right" class="w-4 h-4" />
      <span class="text-on-surface-variant/60">{categoryName}</span>
    </nav>

    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim tracking-tight mb-4">
        {categoryName}
      </h1>
      <p class="text-lg text-on-surface-variant dark:text-on-surface-variant max-w-2xl">
        {count} {count === 1 ? 'análise disponível' : 'análises disponíveis'} nesta categoria
      </p>
    </header>

    {count > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {paginatedPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-on-surface-variant font-body">Ainda não há posts publicados nesta categoria.</p>
      </div>
    )}

    <Pagination
      currentPage={1}
      totalPages={Math.ceil(count / postsPerPage)}
      prevUrl={null}
      nextUrl={count > postsPerPage ? `${basePath}/page/2/` : null}
      basePath={basePath}
    />
  </main>
</Layout>

