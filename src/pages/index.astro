---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { Icon } from 'astro-icon/components';
import { formatDate } from '@utils/date';
import heroHomeImg from '../assets/images/hero-home-stitch.webp';

const posts = await getCollection('posts', ({ data }) => {
  return !data.draft;
});

const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
});

const latestPosts = sortedPosts.slice(0, 3);
const articlePosts = sortedPosts.slice(0, 6);

const categories = [
  {
    name: 'Melhores Marcas',
    icon: 'ph:buildings',
    href: '/melhores-marcas/',
  },
  {
    name: 'Guias por Tamanho',
    icon: 'ph:ruler',
    href: '/guias-por-tamanho/',
  },
  {
    name: 'Colchões de Espuma',
    icon: 'ph:cube',
    href: '/colchoes-de-espuma/',
  },
  {
    name: 'Molas Ensacadas',
    icon: 'ph:circle-dashed',
    href: '/molas-ensacadas/',
  },
  {
    name: 'Saúde e Ortopédicos',
    icon: 'ph:heartbeat',
    href: '/saude-e-ortopedicos/',
  },
  {
    name: 'Colchões Na Caixa',
    icon: 'ph:package',
    href: '/colchoes-na-caixa/',
  },
  {
    name: 'Infláveis e Pneumáticos',
    icon: 'ph:wind',
    href: '/inflaveis-e-pneumaticos/',
  },
  {
    name: 'Acessórios',
    icon: 'ph:bed',
    href: '/acessorios/',
  },
];

const buyerSteps = [
  {
    num: '1',
    title: 'Defina sua Posição de Sono',
    text: 'Quem dorme de lado precisa de mais maciez para os ombros, enquanto quem dorme de costas exige suporte firme para a lombar.',
  },
  {
    num: '2',
    title: 'Considere o Peso Corporal',
    text: 'Pessoas mais pesadas devem buscar colchões híbridos ou de molas ensacadas para garantir longevidade e suporte estrutural.',
  },
  {
    num: '3',
    title: 'Teste o Isolamento de Movimento',
    text: 'Se você dorme acompanhado, este é o fator crucial para não ser acordado toda vez que o parceiro se mexe.',
  },
];
---

<Layout
  title={`${siteConfig.title} | Especialistas em Colchões e Sono de Qualidade`}
  description={siteConfig.description}
  wideContent={true}
  noTopPadding={true}
>
  <main>
    <!-- Hero Section -->
    <section class="relative bg-white dark:bg-surface overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-24 grid lg:grid-cols-2 gap-12 items-center">
        <div class="z-10">
          <span class="inline-block py-1 px-3 rounded-full bg-secondary-container text-on-secondary-container text-sm font-medium mb-6 uppercase tracking-wider">
            Autoridade em Sono
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-[3rem] font-extrabold text-primary dark:text-primary-fixed-dim mb-6 leading-tight tracking-tight">
            O descanso que você merece começa com a escolha certa.
          </h1>
          <p class="text-lg text-on-surface-variant dark:text-on-surface-variant mb-10 max-w-xl leading-relaxed">
            Análises profundas, testes de laboratório e guias imparciais para ajudar você a encontrar o colchão perfeito entre centenas de opções no mercado.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/blog/" class="bg-primary text-on-primary px-8 py-4 rounded-lg font-semibold shadow-lg shadow-primary/20 dark:shadow-primary/30 hover:-translate-y-0.5 transition-all">
              Ver Melhores Colchões
            </a>
            <a href="/guias-de-compra/" class="border-2 border-primary-container text-primary dark:text-primary-fixed-dim px-8 py-4 rounded-lg font-semibold hover:bg-primary-container/5 dark:hover:bg-white/5 transition-all">
              Guia de Compra
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="absolute inset-0 bg-primary-container/5 dark:bg-primary-container/10 rounded-3xl -rotate-3 scale-105"></div>
          <Image 
            class="relative rounded-3xl shadow-2xl object-cover w-full h-[500px] dark:brightness-90"
            src={heroHomeImg}
            alt="Quarto moderno e confortável com colchão premium"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-20">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim mb-4 tracking-tight">Explore por Categoria</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        {categories.map((cat) => (
          <a href={cat.href} class="bg-surface-container-lowest dark:bg-surface-container-high/50 p-6 md:p-8 rounded-xl border border-outline-variant/10 dark:border-outline-variant/10 hover:shadow-xl hover:border-primary/20 dark:hover:border-primary-container/40 transition-all group flex flex-col items-center justify-center text-center">
            <div class="w-14 h-14 bg-secondary-container/30 dark:bg-primary-container/20 rounded-2xl flex items-center justify-center text-secondary dark:text-primary-fixed-dim mb-4 group-hover:scale-110 transition-transform">
              <Icon name={cat.icon} class="w-7 h-7" />
            </div>
            <h3 class="text-sm md:text-base font-semibold text-primary dark:text-primary-fixed-dim">{cat.name}</h3>
          </a>
        ))}
      </div>
    </section>

    <!-- Featured Reviews -->
    <section class="bg-surface-container-low dark:bg-surface-container-high/30 py-16 md:py-20">
      <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim mb-4 tracking-tight">Análises de Destaque</h2>
            <p class="text-on-surface-variant dark:text-on-surface-variant">Produtos testados rigorosamente por nossa equipe editorial.</p>
          </div>
          <a class="text-primary dark:text-primary-fixed-dim font-bold border-b-2 border-primary/20 dark:border-primary-fixed-dim/20 hover:border-primary dark:hover:border-primary-fixed-dim transition-all pb-1" href="/blog/">
            Ver todos os reviews
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {latestPosts.map((post) => (
            <article class="bg-surface-container-lowest dark:bg-surface-container-high rounded-2xl overflow-hidden transition-all group shadow-sm border border-outline-variant/10 dark:border-outline-variant/10 hover:shadow-xl hover:border-primary/20 dark:hover:border-primary-container/40">
              <a href={`/${post.slug}/`} class="block h-48 overflow-hidden relative">
                {post.data.image && (
                  <Image 
                    src={post.data.image} 
                    alt={post.data.title}
                    width={640}
                    height={400}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                )}
              </a>
                <div class="p-8">
                  <p class="text-xs font-bold uppercase tracking-[0.2em] text-on-surface-variant dark:text-on-surface-variant mb-4">
                    {post.data.categories?.[0] || 'Review'}
                  </p>
                  <h3 class="text-xl font-semibold text-primary dark:text-primary-fixed-dim mb-4 group-hover:text-primary-container dark:group-hover:text-primary transition-colors">
                    <a href={`/${post.slug}/`}>{post.data.title}</a>
                  </h3>
                  <p class="text-on-surface-variant dark:text-on-surface-variant text-sm mb-8 leading-relaxed line-clamp-3">
                    {post.data.description}
                  </p>
                  <a href={`/${post.slug}/`} class="block w-full py-3 bg-primary dark:bg-primary-container text-on-primary dark:text-on-primary-container rounded-lg font-bold text-center hover:bg-primary-container dark:hover:bg-primary-fixed hover:text-on-primary dark:hover:text-on-primary-container transition-colors">
                    Ler Review Completo
                  </a>
                </div>
              </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Buyer's Guide Section -->
    <section class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-20">
      <div class="grid lg:grid-cols-2 gap-16 md:gap-20 items-center">
        <div class="order-2 lg:order-1">
          <div class="space-y-12">
            {buyerSteps.map((step) => (
              <div class="flex gap-6">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-bold">
                  {step.num}
                </div>
                <div>
                  <h4 class="text-xl font-semibold text-primary dark:text-primary-fixed-dim mb-2">{step.title}</h4>
                  <p class="text-on-surface-variant dark:text-on-surface-variant">{step.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim mb-6 tracking-tight">Guia do Comprador: Como escolher?</h2>
          <p class="text-lg text-on-surface-variant dark:text-on-surface-variant mb-8 leading-relaxed">
            Comprar um colchão é um investimento de 10 anos na sua saúde. Nosso guia simplifica o processo técnico em passos fáceis de entender.
          </p>
          <div class="bg-primary/5 dark:bg-primary-container/10 p-8 rounded-2xl border-l-4 border-primary dark:border-primary-container">
            <Icon name="material-symbols:lightbulb" class="w-8 h-8 text-primary dark:text-primary-fixed-dim mb-4" />
            <p class="italic text-primary dark:text-primary-fixed-dim font-medium leading-relaxed">
              "A maioria das pessoas escolhe um colchão muito firme. O ideal é o suporte que mantém a coluna alinhada, não a sensação de dureza."
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest Articles -->
    {articlePosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-20">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim mb-4 tracking-tight">Últimos Artigos</h2>
          <p class="text-on-surface-variant dark:text-on-surface-variant">Dicas, guias e análises para ajudar você a dormir melhor.</p>
        </div>
        <a class="text-primary dark:text-primary-fixed-dim font-bold border-b-2 border-primary/20 dark:border-primary-fixed-dim/20 hover:border-primary dark:hover:border-primary-fixed-dim transition-all pb-1" href="/blog/">
          Ver todos <Icon name="material-symbols:arrow-forward" class="w-4 h-4 inline" />
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articlePosts.slice(0, 6).map((post) => (
          <article class="bg-surface-container-lowest dark:bg-surface-container-high rounded-2xl overflow-hidden group shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] hover:shadow-xl transition-all duration-300 border border-outline-variant/10 dark:border-outline-variant/10 hover:border-primary/20 dark:hover:border-primary-container/40 flex flex-col">
            {post.data.image && (
              <a href={`/${post.slug}/`} class="block h-48 overflow-hidden relative">
                <Image
                  src={post.data.image}
                  alt={post.data.title}
                  width={640}
                  height={400}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </a>
            )}
            <div class="p-6 flex flex-col flex-grow">
              <div class="flex items-center gap-3 mb-3">
                {post.data.categories?.[0] && (
                  <span class="inline-block px-3 py-1 rounded-full bg-secondary-container/30 dark:bg-primary-container/20 text-primary dark:text-primary-fixed-dim text-xs font-semibold uppercase tracking-wider">
                    {post.data.categories[0]}
                  </span>
                )}
                {post.data.date && (
                  <span class="text-xs text-on-surface-variant dark:text-on-surface-variant">
                    {formatDate(new Date(post.data.date))}
                  </span>
                )}
              </div>
              <h3 class="text-lg font-semibold text-primary dark:text-primary-fixed-dim mb-2 leading-snug group-hover:text-primary-container dark:group-hover:text-primary transition-colors">
                <a href={`/${post.slug}/`}>{post.data.title}</a>
              </h3>
              <p class="text-on-surface-variant dark:text-on-surface-variant text-sm leading-relaxed line-clamp-3 flex-grow">
                {post.data.description}
              </p>
              <a href={`/${post.slug}/`} class="mt-4 inline-flex items-center gap-2 text-primary dark:text-primary-fixed-dim font-semibold text-sm hover:gap-3 transition-all">
                Continuar lendo <Icon name="material-symbols:arrow-forward" class="w-4 h-4" />
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
    )}

    <!-- Newsletter Section -->
    <section class="bg-primary dark:bg-primary-container py-20 px-6 overflow-hidden relative">
      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6 tracking-tight">Receba ofertas exclusivas e dicas de sono</h2>
        <p class="text-white/80 mb-10 text-lg">Junte-se a mais de 50.000 pessoas que melhoraram suas noites com nosso guia semanal.</p>
        <form class="flex flex-col md:flex-row gap-4 max-w-2xl mx-auto" action="/search/" method="get">
          <input 
            class="flex-grow px-6 py-4 rounded-lg border-none focus:ring-4 focus:ring-primary-container dark:focus:ring-primary bg-white dark:bg-surface-container-lowest text-on-background dark:text-on-surface dark:border dark:border-outline-variant/20"
            placeholder="Seu melhor e-mail" 
            type="email"
            required
          />
          <button class="bg-white text-primary dark:text-on-primary px-10 py-4 rounded-lg font-bold hover:bg-slate-100 dark:hover:bg-slate-200 transition-colors" type="submit">
            Inscrever agora
          </button>
        </form>
        <p class="text-white/60 text-xs mt-6 italic">Prometemos não enviar spam. Você pode cancelar a qualquer momento.</p>
      </div>
    </section>
  </main>
</Layout>