---
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { Icon } from 'astro-icon/components';
import sobreHeroImg from '../assets/images/sobre-hero.webp';
import authorImg from '../assets/images/team-1.webp';

const trustCards = [
  {
    icon: 'material-symbols:verified-user',
    title: 'Independência Editorial',
    description: 'Não aceitamos pagamentos para alterar notas ou reviews. Nossa receita vem de comissões que não influenciam nosso veredito final.',
  },
  {
    icon: 'material-symbols:science',
    title: 'Testes Laboratoriais',
    description: 'Cada produto é submetido a rigorosos testes de suporte de borda, isolamento de movimento e regulação de temperatura em ambiente controlado.',
  },
  {
    icon: 'material-symbols:groups',
    title: 'Experiência Real',
    description: 'Além das máquinas, nossos especialistas de diferentes biotipos testam os colchões em casa para garantir uma perspectiva humana e prática.',
  },
];

const authorSocial = [
  { icon: 'mdi:instagram', url: 'https://instagram.com/guiadecolchao', label: 'Instagram' },
  { icon: 'mdi:twitter', url: 'https://twitter.com/guiadecolchao', label: 'Twitter' },
  { icon: 'mdi:facebook', url: 'https://www.facebook.com/guiadecolchao', label: 'Facebook' },
];
---

<Layout
  title={`Sobre Nós | ${siteConfig.title}`}
  description="Conheça a equipe por trás do Guia de Colchão. Especialistas dedicados a ajudar você a encontrar o colchão perfeito através de análises técnicas rigorosas."
  wideContent={true}
  noTopPadding={true}
>
  <main>
    <!-- Hero Section -->
    <section class="relative h-[500px] md:h-[600px] flex items-center overflow-hidden">
      <div class="absolute inset-0 z-0">
        <Image 
          class="w-full h-full object-cover"
          src={sobreHeroImg}
          alt="Quarto sereno e minimalista com colchão premium"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/80 to-transparent dark:from-surface dark:via-surface/80"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 w-full">
        <div class="max-w-2xl">
          <span class="inline-block text-primary dark:text-primary-fixed-dim font-bold tracking-widest text-sm mb-4 uppercase">Propósito & Excelência</span>
          <h1 class="text-4xl md:text-5xl lg:text-[3rem] font-extrabold text-primary dark:text-primary-fixed-dim mb-6 leading-tight tracking-tight">Nossa Missão</h1>
          <p class="text-lg md:text-xl text-on-surface-variant dark:text-on-surface-variant leading-relaxed">
            Nascemos da necessidade de clareza em um mercado saturado. No Guia de Colchão, nossa missão é democratizar o acesso a um sono de alta performance através de análises técnicas rigorosas e imparciais.
          </p>
        </div>
      </div>
    </section>

    <!-- Authority & Methodology Section -->
    <section class="py-16 md:py-20 bg-white dark:bg-surface">
      <div class="max-w-[720px] mx-auto px-6 md:px-12">
        <h2 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim mb-8 text-center tracking-tight">Autoridade no Descanso</h2>
        <div class="space-y-6 text-on-surface-variant dark:text-on-surface-variant leading-relaxed">
          <p class="text-base md:text-lg">
            Desde nossa fundação, o Guia de Colchão se posicionou como o porto seguro para o consumidor que busca mais do que apenas uma superfície macia. Entendemos que o sono é o pilar fundamental da saúde física e mental, e por isso, tratamos cada review como um diagnóstico técnico.
          </p>
          <p class="text-base md:text-lg">
            Nossa <span class="text-primary dark:text-primary-fixed-dim font-semibold">metodologia de testes</span> não se baseia apenas no toque. Utilizamos sensores de pressão, câmeras térmicas para medir a dissipação de calor e testes de durabilidade mecânica que simulam anos de uso contínuo. Cada colchão que entra em nosso laboratório passa por 200 horas de avaliação antes de receber uma nota final.
          </p>
          <div class="bg-surface-container-low dark:bg-surface-container-high p-8 rounded-xl border-l-4 border-primary dark:border-primary-container my-10">
            <p class="italic text-lg text-primary dark:text-primary-fixed-dim leading-relaxed">
              "Nossa única lealdade é com o seu sono. Se um colchão não entrega o que promete, nós seremos os primeiros a dizer."
            </p>
            <p class="mt-4 text-sm font-medium text-on-surface dark:text-on-surface">— Equipe {siteConfig.title}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Trust Us (Bento Grid Style) -->
    <section class="py-16 md:py-20 bg-surface-bright dark:bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-6 md:px-12">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim mb-4 tracking-tight">Por que confiar em nós?</h2>
          <p class="text-on-surface-variant dark:text-on-surface-variant max-w-2xl mx-auto">Nossos pilares de integridade garantem que você receba informações precisas, independentes e baseadas em dados reais.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {trustCards.map((card) => (
            <div class="bg-surface-container-lowest dark:bg-surface-container-high p-8 rounded-xl shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] border border-outline-variant/10 dark:border-outline-variant/10 hover:shadow-xl transition-shadow duration-300">
              <div class="w-12 h-12 bg-primary-container/10 dark:bg-primary-container/20 rounded-lg flex items-center justify-center mb-6">
                <Icon name={card.icon} class="w-6 h-6 text-primary dark:text-primary-fixed-dim" />
              </div>
              <h3 class="text-xl font-semibold text-primary dark:text-primary-fixed-dim mb-4">{card.title}</h3>
              <p class="text-on-surface-variant dark:text-on-surface-variant text-base leading-relaxed">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- About the Author -->
    <section class="py-16 md:py-20 bg-white dark:bg-surface">
      <div class="max-w-5xl mx-auto px-6 md:px-12">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim mb-4 tracking-tight">Quem faz o Guia de Colchão</h2>
        </div>
        <div class="bg-surface-container-low dark:bg-surface-container-high rounded-2xl p-8 md:p-12 shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] border border-outline-variant/10 dark:border-outline-variant/10">
          <div class="flex flex-col md:flex-row items-center gap-10">
            <div class="flex-shrink-0">
              <Image
                class="w-56 h-56 rounded-full object-cover ring-4 ring-primary/10 dark:ring-primary-container/30 ring-offset-4 dark:ring-offset-surface"
                src={authorImg}
                alt="Leonardo Correia Pinto"
                width={224}
                height={224}
              />
            </div>
            <div class="flex-1 text-center md:text-left">
              <h3 class="text-2xl md:text-3xl font-bold text-primary dark:text-primary-fixed-dim mb-2">Leonardo Correia Pinto</h3>
              <p class="text-secondary dark:text-secondary-fixed-dim font-medium uppercase tracking-wider text-sm mb-6">Fundador & Especialista em Sono</p>
              <p class="text-on-surface-variant dark:text-on-surface-variant leading-relaxed mb-6">
                Leonardo é o fundador do Guia de Colchão, um entusiasta de ergonomia e qualidade de sono que busca traduzir especificações técnicas complexas em recomendações práticas para o dia a dia.
              </p>
              <div class="bg-primary/5 dark:bg-primary-container/10 p-6 rounded-xl border-l-4 border-primary dark:border-primary-container mb-6">
                <p class="italic text-primary dark:text-primary-fixed-dim leading-relaxed">
                  "Nossa única lealdade é com o seu sono. Se um colchão não entrega o que promete, nós seremos os primeiros a dizer."
                </p>
              </div>
              <div class="flex items-center gap-4 justify-center md:justify-start mb-6">
                {authorSocial.map((social) => (
                  <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full bg-surface-container dark:bg-surface-container-high flex items-center justify-center text-primary dark:text-primary-fixed-dim hover:bg-primary hover:text-white dark:hover:bg-primary dark:hover:text-on-primary transition-all"
                    aria-label={social.label}
                  >
                    <Icon name={social.icon} class="w-5 h-5" />
                  </a>
                ))}
              </div>
              <a href="/authors/leonardo/" class="inline-flex items-center gap-2 text-primary dark:text-primary-fixed-dim font-semibold hover:gap-3 transition-all">
                Ver artigos do autor <Icon name="material-symbols:arrow-forward" class="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-20 px-6">
      <div class="max-w-5xl mx-auto bg-primary dark:bg-primary-container rounded-3xl p-12 text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-primary-container/30 to-transparent"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-6 tracking-tight">Pronto para transformar seu descanso?</h2>
          <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto">Explore nossos reviews detalhados e encontre o colchão que vai mudar suas manhãs para sempre.</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a class="bg-white text-primary dark:text-on-primary px-8 py-4 rounded-xl font-bold hover:bg-slate-100 dark:hover:bg-slate-200 transition-colors active:scale-95 duration-200" href="/blog/">Ver Últimos Reviews</a>
            <a class="border border-white/30 text-white px-8 py-4 rounded-xl font-bold hover:bg-white/10 transition-colors active:scale-95 duration-200" href="/guias-de-compra/">Guia de Compra</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>