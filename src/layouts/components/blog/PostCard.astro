---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { formatDate } from '@utils/date';
import { slugify } from '@config/categories';

const { post, horizontal = false } = Astro.props;
const { title, description, image, date, categories, authors, series } = post.data;

const formatCategoryLabel = (category: string) => {
  // Preserve labels that already have custom casing from existing content.
  if (category !== category.toLowerCase()) return category;
  return category
    .split(/[\s-]+/)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
};

// Extract the slug from the canonical URL or use the file name
const slug = post.data.canonical 
  ? new URL(post.data.canonical).pathname.split('/').filter(Boolean).pop()
  : post.slug;

// Check if post is part of a series
const isPartOfSeries = series && Array.isArray(series) && series.length === 2;

// Get author details
const authorEntry = authors && authors.length > 0 ? await getEntry('authors', authors[0]) : null;
const authorName = authorEntry ? authorEntry.data.title : (authors?.[0] || 'Admin');
---

{horizontal ? (
  <a href={`/${slug}/`} class="group flex flex-col sm:flex-row bg-surface-container-lowest dark:bg-surface-container-high/30 rounded-2xl overflow-hidden shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] hover:shadow-xl hover:border-primary/20 dark:hover:border-primary-container/40 transition-all duration-300 h-full border border-outline-variant/10 dark:border-outline-variant/10">
    <div class="sm:w-2/5 aspect-[4/3] sm:aspect-auto sm:h-full relative overflow-hidden bg-surface-variant/50 p-2">
      <div class="w-full h-full relative rounded-xl overflow-hidden">
        {image ? (
          <Image src={image} alt={title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" width={400} height={300} widths={[400, 640, 800]} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw" loading="lazy" decoding="async" />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center bg-surface-container text-on-surface-variant">
            <Icon name="material-symbols:image" class="w-9 h-9 opacity-20" />
          </div>
        )}
        {categories && categories.length > 0 && (
          <div class="absolute top-3 left-3 z-10">
            <span class="bg-primary dark:bg-primary-container text-on-primary dark:text-on-primary-container text-[10px] font-bold px-2.5 py-1 rounded-md uppercase tracking-wider shadow-sm">{formatCategoryLabel(categories[0])}</span>
          </div>
        )}
      </div>
    </div>
    <div class="sm:w-3/5 p-6 md:p-8 flex flex-col justify-center">
      <h3 class="font-headline text-xl md:text-2xl font-semibold text-on-surface dark:text-on-surface mb-3 leading-tight group-hover:text-primary dark:group-hover:text-primary-fixed-dim transition-colors line-clamp-3">
        {title}
      </h3>
      {description && (
        <p class="font-body text-sm md:text-base text-on-surface-variant dark:text-on-surface-variant line-clamp-2 md:line-clamp-3 mb-5 leading-relaxed">
          {description}
        </p>
      )}
      <div class="mt-auto">
         <span class="inline-flex items-center gap-2 text-primary dark:text-primary-fixed-dim font-semibold text-sm group-hover:gap-3 transition-all">
           Ler Review <Icon name="material-symbols:arrow-forward" class="w-4 h-4" />
         </span>
      </div>
    </div>
  </a>
) : (
  <article class="flex flex-col group h-full">
    <a href={`/${slug}/`} class="relative mb-5 overflow-hidden rounded-2xl aspect-[16/10] bg-surface-container-low block shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] hover:shadow-xl transition-all duration-300">
      {image ? (
        <Image src={image} alt={title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" width={640} height={400} widths={[400, 640, 800]} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw" loading="lazy" decoding="async" />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-surface-container text-on-surface-variant">
          <Icon name="material-symbols:image" class="w-14 h-14 opacity-20" />
        </div>
      )}
      {categories && categories.length > 0 && (
        <div class="absolute top-3 left-3 z-10">
          <span class="bg-primary dark:bg-primary-container text-on-primary dark:text-on-primary-container text-[10px] font-bold px-2.5 py-1 rounded-md uppercase tracking-wider shadow-sm">{formatCategoryLabel(categories[0])}</span>
        </div>
      )}
    </a>
    
    <h3 class="font-headline text-xl font-semibold text-on-surface dark:text-on-surface mb-3 group-hover:text-primary dark:group-hover:text-primary-fixed-dim transition-colors line-clamp-2">
      <a href={`/${slug}/`}>{title}</a>
    </h3>
    
    {description && (
      <p class="font-body text-sm text-on-surface-variant dark:text-on-surface-variant leading-relaxed mb-5 line-clamp-3">
        {description}
      </p>
    )}
    
    <div class="mt-auto flex items-center justify-between border-t border-outline-variant/10 dark:border-outline-variant/10 pt-4">
      <a href={`/${slug}/`} class="flex items-center gap-2 text-primary dark:text-primary-fixed-dim font-semibold text-sm group-hover:gap-3 transition-all">
        Ler Review <Icon name="material-symbols:arrow-forward" class="w-4 h-4" />
      </a>
      {date && (
        <span class="text-xs text-on-surface-variant/60 flex items-center gap-1.5">
          <Icon name="material-symbols:calendar-today" class="w-3.5 h-3.5" />
          {formatDate(date)}
        </span>
      )}
    </div>
  </article>
)}
