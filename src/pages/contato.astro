---
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "@config/site";
import config from "@config/config.json";
import { Image } from "astro:assets";
import { Icon } from 'astro-icon/components';
import escritorioImg from "../assets/images/escritorio-contato.webp";

const { email, phone, address } = config.contactinfo;
const { contact_form_action } = config.params;

const title = "Contato";
const description = "Fale com o Guia Robô Aspirador. Tire suas dúvidas sobre tecnologia, manutenção ou proponha parcerias.";
---

<Layout
  title={`${title} | ${siteConfig.title}`}
  description={description}
  wideContent={true}
  noTopPadding={true}
>
  <main class="max-w-7xl mx-auto px-6 py-24 md:py-32">
    <!-- Hero Section -->
    <section class="mb-16 md:mb-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="space-y-8">
          <h1 class="text-6xl md:text-8xl font-headline font-extrabold tracking-tighter text-on-surface leading-[0.9] dark:text-primary-fixed-dim">
            Conecte-se com a <span class="text-primary-container dark:text-primary-fixed">Precisão.</span>
          </h1>
          <p class="text-xl md:text-2xl text-on-surface-variant max-w-xl font-light leading-relaxed italic">
            Dúvidas sobre manutenção, sugestões de novos modelos para review ou propostas de parcerias técnicas? Nossa equipe editorial está pronta para responder.
          </p>
          <div class="flex flex-col gap-6 pt-4">
            <!-- Email -->
            <div class="flex items-center gap-4 text-on-surface group">
              <div class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                <Icon name="material-symbols:mail" class="w-6 h-6 text-primary group-hover:text-white" />
              </div>
              <a href={`mailto:${email}`} class="text-xl font-headline font-bold text-primary dark:text-primary-fixed-dim hover:opacity-80 transition-opacity">
                {email}
              </a>
            </div>

            <!-- Telefone -->
            {phone && (
              <div class="flex items-center gap-4 text-on-surface group">
                <div class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                  <Icon name="material-symbols:call" class="w-6 h-6 text-primary group-hover:text-white" />
                </div>
                <span class="text-xl font-headline font-bold text-primary dark:text-primary-fixed-dim">
                  {phone}
                </span>
              </div>
            )}

            <!-- Endereço -->
            {address && (
              <div class="flex items-center gap-4 text-on-surface group">
                <div class="w-12 h-12 rounded-full bg-primary-container/10 flex items-center justify-center group-hover:bg-primary transition-colors duration-300">
                  <Icon name="material-symbols:location-on" class="w-6 h-6 text-primary group-hover:text-white" />
                </div>
                <span class="text-base font-light text-on-surface-variant max-w-[280px]">
                  {address}
                </span>
              </div>
            )}
          </div>
        </div>
        <div class="relative group">
          <div class="absolute inset-0 bg-primary-container/5 rounded-[2.5rem] -rotate-2 scale-105 transition-transform group-hover:rotate-0"></div>
          <Image 
            alt="Escritório Guia Robô Aspirador" 
            class="relative z-10 w-full aspect-[4/3] object-cover rounded-[2.5rem] shadow-2xl transition-transform duration-700 hover:scale-[1.02]" 
            src={escritorioImg}
          />
        </div>
      </div>
    </section>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <!-- Contact Form Area -->
      <div class="lg:col-span-7 bg-surface-container-lowest dark:bg-surface-container-high/50 rounded-[2.5rem] p-8 md:p-16 shadow-[0px_12px_32px_rgba(13,30,37,0.06)] border border-outline-variant/10">
        <form action={contact_form_action || "#"} method="POST" class="space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-3">
              <label class="text-[10px] font-headline font-bold uppercase tracking-[0.2em] text-on-surface-variant/60 ml-2">Nome Completo</label>
              <input 
                class="w-full bg-surface-container-low dark:bg-surface-container-high/50 border-none rounded-2xl p-5 focus:ring-2 focus:ring-primary-container/20 transition-all text-on-surface" 
                placeholder="Ex Carlos Silva" 
                type="text"
                name="name"
                required
              />
            </div>
            <div class="space-y-3">
              <label class="text-[10px] font-headline font-bold uppercase tracking-[0.2em] text-on-surface-variant/60 ml-2">E-mail de Contato</label>
              <input 
                class="w-full bg-surface-container-low dark:bg-surface-container-high/50 border-none rounded-2xl p-5 focus:ring-2 focus:ring-primary-container/20 transition-all text-on-surface" 
                placeholder="nome@email.com" 
                type="email"
                name="email"
                required
              />
            </div>
          </div>
          <div class="space-y-3">
            <label class="text-[10px] font-headline font-bold uppercase tracking-[0.2em] text-on-surface-variant/60 ml-2">Assunto</label>
            <select 
              class="w-full bg-surface-container-low dark:bg-surface-container-high/50 border-none rounded-2xl p-5 focus:ring-2 focus:ring-primary-container/20 transition-all text-on-surface appearance-none"
              name="subject"
              required
            >
              <option>Suporte Técnico</option>
              <option>Sugestão de Produto para Review</option>
              <option>Imprensa / Mídia</option>
              <option>Parceria Comercial</option>
            </select>
          </div>
          <div class="space-y-3">
            <label class="text-[10px] font-headline font-bold uppercase tracking-[0.2em] text-on-surface-variant/60 ml-2">Mensagem</label>
            <textarea 
              class="w-full bg-surface-container-low dark:bg-surface-container-high/50 border-none rounded-2xl p-5 focus:ring-2 focus:ring-primary-container/20 transition-all resize-none text-on-surface" 
              placeholder="Como podemos ajudar você hoje?" 
              rows="6"
              name="message"
              required
            ></textarea>
          </div>
          <button 
            class="w-full md:w-auto px-16 py-5 bg-primary text-on-primary font-headline font-bold rounded-2xl hover:shadow-2xl hover:bg-primary/90 hover:-translate-y-1 transition-all duration-300" 
            type="submit"
          >
            Enviar Mensagem
          </button>
        </form>
      </div>

      <!-- Side Info: Business & Reviews -->
      <div class="lg:col-span-5 space-y-8">
        <!-- Business Inquiries Card -->
        <div class="bg-surface-container-low dark:bg-surface-container-high/30 rounded-3xl p-10 space-y-6 border border-outline-variant/10">
          <div class="w-14 h-14 bg-tertiary-container rounded-2xl flex items-center justify-center text-on-tertiary-container mb-2">
            <Icon name="material-symbols:business-center" class="w-8 h-8" />
          </div>
          <h3 class="text-3xl font-headline font-bold text-primary dark:text-primary-fixed-dim italic">Consultoria & Parcerias</h3>
          <p class="text-on-surface-variant leading-relaxed">
            Para fabricantes interessados em submeter novos modelos para nossos protocolos de testes laboratoriais ou campanhas publicitárias exclusivas.
          </p>
          <a class="inline-flex items-center gap-3 text-primary dark:text-primary-fixed-dim font-bold text-lg hover:underline transition-all" href={`mailto:${email}`}>
            {email}
            <Icon name="material-symbols:arrow-forward" class="w-4 h-4" />
          </a>
        </div>

        <!-- Product Request Card -->
        <div class="bg-surface-container-low dark:bg-surface-container-high/30 rounded-3xl p-10 space-y-6 border border-outline-variant/10">
          <div class="w-14 h-14 bg-secondary-container rounded-2xl flex items-center justify-center text-on-secondary-container mb-2">
            <Icon name="material-symbols:rate-review" class="w-8 h-8" />
          </div>
          <h3 class="text-3xl font-headline font-bold text-primary dark:text-primary-fixed-dim italic">Pedido de Review</h3>
          <p class="text-on-surface-variant leading-relaxed">
            Viu um robô novo no mercado e quer nossa análise técnica? Deixe-nos saber quais recursos você quer que sejam testados primeiro.
          </p>
          <div class="pt-4 border-t border-outline-variant/10">
            <div class="flex -space-x-3 mb-4">
              <img class="w-10 h-10 rounded-full border-2 border-surface-container-low object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCf84Ni8OeSnZBBILlYwmaiAW1NS8QlrsE5rFzmOmSlTMka0-1jywNvDD6M8y2GYOmvQ28nj2V2wFMDruN97AnJ_iJsoGyYnLIHJMnglliE_prU-7PmWg-Rpyp-1tsOw0J4LJ7W2bqMj8E_iZUBNFkVnR6LaeO6ptVEwp4mencA47Y2v0kwvZY69W1zc5_Y9WGMI1N9ncMYJUpLcg4gRHfrqHlli47bxkh6N46C2vpr6CrtTuGXDiY-Pkn8Cv6HhRwLiCeq7lBPbg4" alt="Editor" />
              <img class="w-10 h-10 rounded-full border-2 border-surface-container-low object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA2oboCeBi-VkcCENoD36kjb0j29-Wh7L_Jdl-pfSGRVMYqafjojWn23bSThXFVxGBcLPTdgOQxOhzv-XuZXnHTRg4QQpRvaPzxOlf0TEwWwCzIfEpV-tCsxhE_XreuM0wL3XQXEaxTo6zJYRkIkOvKcyxJVq49Odv-7E8E7wn3G_AN-eTAfl9qwfO-PAHNcSrHAbJdg_gFucX-FTj06ZoFnkB4HOCIJX_EGJfoC4i29AJB1EEiXJf-NkBfqDGZI9lApDV9nL6ZbA4" alt="Reviewer" />
              <div class="w-10 h-10 rounded-full bg-primary-container text-white border-2 border-surface-container-low flex items-center justify-center text-[10px] font-bold">+5</div>
            </div>
            <p class="text-xs text-on-surface-variant/70 font-bold uppercase tracking-widest">Equipe Editorial</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
