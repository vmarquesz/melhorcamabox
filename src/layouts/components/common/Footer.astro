---
import { siteConfig } from "@config/site";
import { Icon } from "astro-icon/components";
import social from "@config/social.json";
---

<footer class="w-full mt-20 bg-surface-container-lowest border-t border-outline-variant/10">
  <div class="max-w-container-max mx-auto px-gutter py-16">
    <div class="flex flex-col md:flex-row justify-between items-start gap-12">
      <!-- Brand Info -->
      <div class="max-w-sm">
        <div class="flex items-center gap-2 mb-4">
          <span class="font-headline text-xl font-bold text-primary dark:text-primary-fixed-dim">
            {siteConfig.title}
          </span>
        </div>
        <p class="font-body text-sm text-on-surface-variant leading-relaxed mb-6">
          Referência número 1 em testes independentes de fritadeiras a ar no Brasil. Nossa missão é trazer precisão industrial com calor culinário.
        </p>
        <div class="flex gap-4">
          {social.instagram && (
            <a href={social.instagram} target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="Instagram">
              <Icon name="mdi:instagram" class="w-5 h-5" />
            </a>
          )}
          {social.youtube && (
            <a href={social.youtube} target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="YouTube">
              <Icon name="mdi:youtube" class="w-5 h-5" />
            </a>
          )}
          {social.facebook && (
            <a href={social.facebook} target="_blank" rel="noopener noreferrer" class="text-on-surface-variant hover:text-primary transition-colors" aria-label="Facebook">
              <Icon name="mdi:facebook" class="w-5 h-5" />
            </a>
          )}
        </div>
      </div>

      <!-- Navigation Columns -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-12">
        <div>
          <h4 class="font-bold text-on-surface mb-4 text-sm uppercase tracking-wider">Modelos</h4>
          <ul class="space-y-3">
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/categorias/">Basket-style</a></li>
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/categorias/">Oven-style</a></li>
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/categorias/">Dual-basket</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-on-surface mb-4 text-sm uppercase tracking-wider">Conteúdo</h4>
          <ul class="space-y-3">
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/blog/">Melhores do Ano</a></li>
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/dicas-e-manutencao/">Dicas & Receitas</a></li>
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/sobre-nos/">Sobre Nós</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-on-surface mb-4 text-sm uppercase tracking-wider">Legal</h4>
          <ul class="space-y-3">
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/contato/">Contato</a></li>
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/politica-de-privacidade/">Privacidade</a></li>
            <li><a class="text-on-surface-variant font-body text-sm hover:text-primary transition-colors" href="/termos-de-uso/">Termos</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="max-w-container-max mx-auto mt-12 pt-8 border-t border-outline-variant/20">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-on-surface-variant font-body text-xs">
          © {new Date().getFullYear()} {siteConfig.title}. Industrial Precision meets Culinary Warmth.
        </p>
        <p class="text-on-surface-variant/60 font-body text-[10px] italic">
          Comprando através de nossos links, podemos ganhar uma comissão sem custo adicional para você.
        </p>
      </div>
    </div>
  </div>
</footer>
