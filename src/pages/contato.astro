---
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { Icon } from 'astro-icon/components';
import contatoAccentImg from '../assets/images/contato-accent.webp';

const faqItems = [
  {
    question: 'Quanto tempo leva a resposta?',
    answer: 'Nossa equipe editorial responde a todas as consultas em um prazo de 24 a 48 horas úteis.',
  },
  {
    question: 'Vocês vendem colchões diretamente?',
    answer: 'Não. Somos um site de avaliações independente. Fornecemos links para lojas parceiras confiáveis.',
  },
  {
    question: 'Como são feitos os testes?',
    answer: 'Utilizamos uma metodologia rigorosa que inclui testes de pressão, durabilidade e transferência de movimento.',
  },
];
---

<Layout
  title={`Contato | ${siteConfig.title}`}
  description="Entre em contato com a equipe do Guia de Colchão. Nossos especialistas em sono estão prontos para ajudar você a encontrar o colchão perfeito."
  wideContent={true}
  noTopPadding={true}
>
  <main class="pt-24 pb-16 md:pb-20">
    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <!-- Hero Section -->
      <div class="mb-16 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold text-primary dark:text-primary-fixed-dim mb-4 tracking-tight">Fale Conosco</h1>
        <p class="text-lg md:text-xl text-on-surface-variant dark:text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
          Nossa equipe de especialistas em sono está pronta para ajudar você a encontrar o colchão perfeito ou responder qualquer dúvida editorial.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Contact Form Column -->
        <div class="lg:col-span-7 bg-surface-container-lowest dark:bg-surface-container-high p-8 md:p-12 rounded-xl shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] border border-outline-variant/10 dark:border-outline-variant/10">
          <form action="#" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-sm font-medium text-on-surface-variant dark:text-on-surface-variant" for="name">Nome</label>
                <input 
                  class="w-full px-4 py-3 rounded-lg border border-outline-variant dark:border-outline-variant/30 bg-surface-container-low dark:bg-surface-container text-on-surface dark:text-on-surface focus:border-primary dark:focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all"
                  id="name" 
                  name="name" 
                  placeholder="Seu nome completo" 
                  type="text"
                  required
                />
              </div>
              <div class="space-y-2">
                <label class="text-sm font-medium text-on-surface-variant dark:text-on-surface-variant" for="email">E-mail</label>
                <input 
                  class="w-full px-4 py-3 rounded-lg border border-outline-variant dark:border-outline-variant/30 bg-surface-container-low dark:bg-surface-container text-on-surface dark:text-on-surface focus:border-primary dark:focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all"
                  id="email" 
                  name="email" 
                  placeholder="exemplo@email.com" 
                  type="email"
                  required
                />
              </div>
            </div>
            <div class="space-y-2">
              <label class="text-sm font-medium text-on-surface-variant dark:text-on-surface-variant" for="subject">Assunto</label>
              <input 
                class="w-full px-4 py-3 rounded-lg border border-outline-variant dark:border-outline-variant/30 bg-surface-container-low dark:bg-surface-container text-on-surface dark:text-on-surface focus:border-primary dark:focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all"
                id="subject" 
                name="subject" 
                placeholder="Como podemos ajudar?" 
                type="text"
                required
              />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-medium text-on-surface-variant dark:text-on-surface-variant" for="message">Mensagem</label>
              <textarea 
                class="w-full px-4 py-3 rounded-lg border border-outline-variant dark:border-outline-variant/30 bg-surface-container-low dark:bg-surface-container text-on-surface dark:text-on-surface focus:border-primary dark:focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all resize-none"
                id="message" 
                name="message" 
                placeholder="Escreva sua mensagem aqui..." 
                rows="6"
                required
              ></textarea>
            </div>
            <button 
              class="w-full md:w-auto px-8 py-4 bg-primary text-on-primary font-semibold rounded-lg hover:bg-primary-container active:scale-[0.98] transition-all flex items-center justify-center gap-2"
              type="submit"
            >
              <span>Enviar Mensagem</span>
              <Icon name="material-symbols:send" class="w-5 h-5" />
            </button>
          </form>
        </div>

        <!-- Sidebar Content -->
        <div class="lg:col-span-5 space-y-8">
          <!-- Support Info -->
          <div class="bg-surface-container-lowest dark:bg-surface-container-high p-8 rounded-xl border border-outline-variant/10 dark:border-outline-variant/10 shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)]">
            <h2 class="text-xl font-semibold text-primary dark:text-primary-fixed-dim mb-6">Informações de Suporte</h2>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-secondary-container dark:bg-primary-container/20 flex items-center justify-center text-on-secondary-container dark:text-primary-fixed-dim flex-shrink-0">
                  <Icon name="material-symbols:mail" class="w-5 h-5" />
                </div>
                <div>
                  <p class="text-sm text-on-surface-variant dark:text-on-surface-variant">E-mail</p>
                  <p class="text-base font-semibold text-on-surface dark:text-on-surface">contato@guiadecolchao.com.br</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-secondary-container dark:bg-primary-container/20 flex items-center justify-center text-on-secondary-container dark:text-primary-fixed-dim flex-shrink-0">
                  <Icon name="material-symbols:share" class="w-5 h-5" />
                </div>
                <div>
                  <p class="text-sm text-on-surface-variant dark:text-on-surface-variant mb-2">Redes Sociais</p>
                  <div class="flex gap-4">
                    <a class="text-primary dark:text-primary-fixed-dim hover:text-secondary dark:hover:text-secondary transition-colors" href="https://instagram.com/guiadecolchao" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                      <Icon name="mdi:instagram" class="w-5 h-5" />
                    </a>
                    <a class="text-primary dark:text-primary-fixed-dim hover:text-secondary dark:hover:text-secondary transition-colors" href="https://twitter.com/guiadecolchao" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                      <Icon name="mdi:twitter" class="w-5 h-5" />
                    </a>
                    <a class="text-primary dark:text-primary-fixed-dim hover:text-secondary dark:hover:text-secondary transition-colors" href="https://www.facebook.com/guiadecolchao" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                      <Icon name="mdi:facebook" class="w-5 h-5" />
                    </a>
                    <a class="text-primary dark:text-primary-fixed-dim hover:text-secondary dark:hover:text-secondary transition-colors" href="https://www.youtube.com/@guiadecolchao" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                      <Icon name="mdi:youtube" class="w-5 h-5" />
                    </a>
                    <a class="text-primary dark:text-primary-fixed-dim hover:text-secondary dark:hover:text-secondary transition-colors" href="https://www.linkedin.com/company/guiadecolchao" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                      <Icon name="mdi:linkedin" class="w-5 h-5" />
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- FAQ Section -->
          <div class="bg-surface-container-low dark:bg-surface-container-high/50 p-8 rounded-xl border border-outline-variant/10 dark:border-outline-variant/10 shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)]">
            <h2 class="text-xl font-semibold text-primary dark:text-primary-fixed-dim mb-6">FAQ Rápido</h2>
            <div class="space-y-4">
              {faqItems.map((item, i) => (
                <details class="group bg-surface-container-lowest dark:bg-surface-container-high rounded-lg border border-outline-variant/10 dark:border-outline-variant/10 overflow-hidden" open={i === 0}>
                  <summary class="flex justify-between items-center p-4 cursor-pointer font-semibold list-none text-on-surface dark:text-on-surface">
                    {item.question}
                    <Icon name="material-symbols:expand-more" class="w-5 h-5 transition-transform group-open:rotate-180" />
                  </summary>
                  <div class="px-4 pb-4 text-on-surface-variant dark:text-on-surface-variant text-sm leading-relaxed">
                    {item.answer}
                  </div>
                </details>
              ))}
            </div>
          </div>

          <!-- Visual Accent Card -->
          <div class="relative h-48 rounded-xl overflow-hidden group">
            <Image 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              src={contatoAccentImg}
              alt="Quarto minimalista com luz natural suave"
              width={800}
              height={400}
            />
            <div class="absolute inset-0 bg-primary/30 dark:bg-primary-container/40 backdrop-blur-[2px] flex flex-col justify-center px-8">
              <p class="text-white font-bold text-lg leading-tight">Garantindo sua melhor noite de sono, todos os dias.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>