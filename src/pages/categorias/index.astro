---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@config/site';
import { featuredCategories, slugify } from '@config/categories';

// Get all blog posts
const posts = await getCollection('posts', ({ data }) => {
  return !data.draft;
});

const normalizeCategory = (value: string) => slugify(value);

const dynamicCategories = [...new Set(posts.flatMap(post => post.data.categories || []))]
  .map((category) => {
    const slug = normalizeCategory(category);
    return {
      slug,
      name: category,
      icon: 'mdi:folder',
      description: '',
    };
  });

const mergedCategories = [...featuredCategories];
for (const category of dynamicCategories) {
  if (!mergedCategories.some((item) => item.slug === category.slug)) {
    mergedCategories.push(category);
  }
}

const categoryCounts = mergedCategories
  .map(({ name, slug, icon }) => {
    const postCount = posts.filter((post) =>
      (post.data.categories || []).some((category) => normalizeCategory(category) === slug)
    ).length;

    return { name, count: postCount, slug, icon };
  })
  .sort((a, b) => b.count - a.count);
---

<Layout
  title={`Categorias - ${siteConfig.title}`}
  description="Veja todos os conteúdos organizados por categoria"
>
  <main class="max-w-7xl mx-auto px-6 md:px-12 py-16 md:py-20">
    <nav class="flex items-center gap-2 text-sm font-medium text-on-surface-variant mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <Icon name="material-symbols:chevron-right" class="w-4 h-4" />
      <span class="text-on-surface-variant/60">Categorias</span>
    </nav>

    <header class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-primary dark:text-primary-fixed-dim tracking-tight mb-4">
        Categorias
      </h1>
      <p class="text-lg text-on-surface-variant dark:text-on-surface-variant max-w-2xl">
        Navegue pelos posts do Guia de Colchão por categoria
      </p>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoryCounts.map(({ name, count, slug, icon }) => (
        <a
          href={`/${slug}/`}
          class="flex items-center justify-between p-6 bg-surface-container-lowest dark:bg-surface-container-high/50 rounded-xl border border-outline-variant/10 dark:border-outline-variant/10 shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] hover:shadow-xl hover:border-primary/20 dark:hover:border-primary-container/40 transition-all active:scale-[0.98]"
        >
          <div class="flex items-center">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-primary-container/10 dark:bg-primary-container/20 text-primary dark:text-primary-fixed-dim mr-4">
              <Icon name={icon} class="w-6 h-6" />
            </div>
            <span class="font-semibold font-headline text-on-surface dark:text-on-surface">
              {name}
            </span>
          </div>
          <span class="bg-primary-container/10 dark:bg-primary-container/20 text-primary dark:text-primary-fixed-dim text-xs font-semibold px-3 py-1 rounded-full min-w-20 text-center shrink-0">
            {count} {count === 1 ? 'post' : 'posts'}
          </span>
        </a>
      ))}
    </div>

    {categoryCounts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-on-surface-variant font-body">Nenhuma categoria encontrada.</p>
      </div>
    )}
  </main>
</Layout>
