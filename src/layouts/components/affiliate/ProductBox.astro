---
interface Props {
  title: string;
  image: string;
  link: string;
  description?: string;
}

const { title, image, link, description } = Astro.props;
---

<div class="product-box not-prose my-12 bg-surface-container-lowest dark:bg-surface-container-high/30 rounded-xl border border-outline-variant/10 dark:border-outline-variant/10 grid grid-cols-1 md:grid-cols-[260px_1fr] md:gap-12 items-center p-8 md:p-10 shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] transition-all duration-300 hover:shadow-xl hover:border-primary/20 dark:hover:border-primary-container/40">
  
  <!-- Left Column: Image -->
  <a href={link} target="_blank" rel="nofollow sponsored" class="group w-full max-w-[260px] mx-auto mb-8 md:mb-0 bg-white rounded-xl shadow-sm p-6 flex items-center justify-center aspect-square shrink-0 hover:shadow-md transition-all duration-300">
    <img 
      src={image} 
      alt={title} 
      class="max-h-full object-contain transition-transform duration-300 group-hover:scale-105" 
      loading="lazy"
      width="260"
      height="260"
    />
  </a>
  
  <!-- Right Column: Content -->
  <div class="flex flex-col text-center md:text-left justify-center items-center md:items-start">
    <a 
      href={link} 
      target="_blank" 
      rel="nofollow sponsored" 
      class="font-headline text-2xl md:text-3xl font-bold text-primary dark:text-primary-fixed-dim hover:text-primary-container dark:hover:text-primary transition-colors leading-tight mb-6 tracking-tight"
    >
      {title}
    </a>
    
    {description && (
      <p class="font-body text-on-surface-variant dark:text-on-surface-variant text-base md:text-lg leading-relaxed mb-8 max-w-xl">
        {description}
      </p>
    )}
    
    <a 
      href={link} 
      target="_blank" 
      rel="nofollow sponsored" 
      class="inline-flex items-center justify-center w-full sm:w-auto bg-primary dark:bg-primary-container text-on-primary dark:text-on-primary-container px-10 py-4 rounded-lg font-bold font-headline hover:bg-primary-container dark:hover:bg-primary-fixed hover:text-on-primary dark:hover:text-on-primary-container hover:shadow-lg transition-all text-sm uppercase tracking-[0.15em]"
    >
      Ver Preço na Amazon
    </a>
  </div>

</div>
