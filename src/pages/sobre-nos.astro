---
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
import { Icon } from 'astro-icon/components';
import methodologyImg from '../assets/images/methodology-stitch.webp';
import aboutHeroImg from '../assets/images/about-hero-stitch.webp';
import authorImg from '../assets/images/authors/eduardo.webp';

const methodologyCards = [
  {
    icon: 'material-symbols:analytics',
    title: 'Rigor Técnico',
    description: 'Utilizamos termômetros infravermelhos e decibelímetros profissionais para medir a temperatura interna real e o ruído de operação de cada aparelho.',
    tags: ['Precisão Térmica', 'Decibéis'],
    span: 'md:col-span-8',
    style: 'default',
  },
  {
    icon: 'material-symbols:speed',
    title: 'Performance Real',
    description: 'Testamos com receitas padronizadas: batatas fritas congeladas, frango a passarinho e pão de queijo.',
    span: 'md:col-span-4',
    style: 'primary',
  },
  {
    icon: 'material-symbols:balance',
    title: 'Imparcialidade Total',
    description: 'Não aceitamos produtos gratuitos em troca de reviews positivos. Todos os aparelhos são comprados ou devolvidos após o teste.',
    span: 'md:col-span-4',
    style: 'dark',
  },
  {
    icon: 'material-symbols:cleaning-services',
    title: 'Durabilidade & Limpeza',
    description: 'Avaliamos a resistência do cesto após 50 ciclos de lavagem e a facilidade de remoção de resíduos de gordura, garantindo longevidade.',
    span: 'md:col-span-8',
    style: 'default',
    image: methodologyImg,
  },
];
---

<Layout
  title={`Sobre Nós | ${siteConfig.title}`}
  description="Conheça a equipe por trás do Guia de Air Fryer. Especialistas dedicados a ajudar você a encontrar o air fryer perfeito através de análises práticas rigorosas."
  wideContent={true}
  noTopPadding={true}
>
  <!-- Hero Section -->
  <section class="relative w-full py-16 md:py-24 overflow-hidden bg-surface-container-lowest">
    <div class="max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
      <div class="md:col-span-7 flex flex-col gap-6">
        <span class="inline-block px-3 py-1 bg-primary-container text-on-primary-container text-xs font-semibold rounded uppercase tracking-widest w-fit">Compromisso Editorial</span>
        <h1 class="font-headline text-4xl md:text-5xl font-bold text-on-surface leading-tight">Nossa Missão: Excelência em Fritadeiras a Ar</h1>
        <p class="font-body text-lg text-on-surface-variant max-w-[600px]">
          No Guia de Air Fryer, unimos a paixão pela culinária saudável com o rigor da análise tecnológica. Nossa missão é guiar sua jornada na cozinha moderna através de dados precisos e experiências reais.
        </p>
        <div class="flex gap-8 pt-4">
          <div class="flex flex-col">
            <span class="text-3xl md:text-4xl font-bold text-primary">500+</span>
            <span class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Modelos Testados</span>
          </div>
          <div class="w-px h-12 bg-outline-variant"></div>
          <div class="flex flex-col">
            <span class="text-3xl md:text-4xl font-bold text-primary">100k+</span>
            <span class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant">Leitores Mensais</span>
          </div>
        </div>
      </div>
      <div class="md:col-span-5 relative">
        <div class="aspect-square rounded-xl overflow-hidden border border-outline-variant shadow-lg bg-surface-container">
          <Image
            src={aboutHeroImg}
            alt="Especialista Guia de Air Fryer"
            width={600}
            height={600}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Institutional Text -->
  <section class="py-16 md:py-24 bg-background">
    <div class="max-w-[720px] mx-auto px-gutter flex flex-col gap-6">
      <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-surface border-l-4 border-primary pl-6">Paixão pela Praticidade e Saúde</h2>
      <p class="font-body text-on-surface-variant">
        Nascemos da necessidade de desmistificar a tecnologia de convecção de alta velocidade. Acreditamos que a cozinha moderna deve ser eficiente sem sacrificar o sabor ou a saúde. Por isso, cada review no Guia de Air Fryer não é apenas uma lista de especificações, mas um mergulho profundo no desempenho real em ambientes domésticos.
      </p>
      <p class="font-body text-on-surface-variant">
        Investimos centenas de horas em cozinhas de teste, avaliando desde a precisão térmica dos termostatos até a facilidade de limpeza dos revestimentos antiaderentes. Nosso objetivo é que você compre com confiança, sabendo exatamente o que esperar do seu próximo investimento culinário.
      </p>
    </div>
  </section>

  <!-- Methodology Section -->
  <section class="py-16 md:py-24 bg-surface-container-low">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="text-center mb-12 flex flex-col gap-4 items-center">
        <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-surface">Nossa Metodologia</h2>
        <p class="font-body text-on-surface-variant max-w-[600px]">Como garantimos que nossos reviews sejam os mais confiáveis da internet.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
        {methodologyCards.map((card) => (
          <div class:list={[
            card.span,
            "p-6 border border-outline-variant rounded-xl flex items-center gap-6 transition-shadow hover:shadow-md",
            card.style === 'primary' ? "bg-primary text-on-primary border-primary" : "",
            card.style === 'dark' ? "bg-surface-container-highest" : "",
            card.style === 'default' ? "bg-surface-container-lowest" : "",
          ]}>
            <div class="flex-1">
              <div class:list={[
                "w-12 h-12 rounded-lg flex items-center justify-center mb-4",
                card.style === 'primary' ? "bg-white/20" : "bg-primary/10 text-primary",
              ]}>
                <Icon name={card.icon} class:list={[
                  "w-6 h-6",
                  card.style === 'primary' ? "text-white" : "text-primary",
                ]} />
              </div>
              <h3 class:list={[
                "font-headline text-xl font-semibold mb-3",
                card.style === 'primary' ? "text-white" : "text-on-surface",
              ]}>{card.title}</h3>
              <p class:list={[
                "font-body",
                card.style === 'primary' ? "text-white/90" : "text-on-surface-variant",
              ]}>{card.description}</p>
              {card.tags && (
                <div class="flex gap-2 mt-4">
                  {card.tags.map((tag) => (
                    <span class="px-2 py-1 bg-surface-container-high rounded text-xs font-semibold text-on-surface-variant">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            {card.image && (
              <div class="hidden md:block w-1/3 aspect-video rounded-lg overflow-hidden flex-shrink-0">
                <Image src={card.image} alt={card.title} width={400} height={225} class="w-full h-full object-cover" />
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Author Section -->
  <section class="py-16 md:py-24 bg-background">
    <div class="max-w-5xl mx-auto px-gutter">
      <div class="text-center mb-12">
        <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-surface">Quem faz o Guia de Air Fryer</h2>
      </div>
      <div class="bg-surface-container-low rounded-2xl p-8 md:p-12 border border-outline-variant">
        <div class="flex flex-col md:flex-row items-center gap-10">
          <div class="flex-shrink-0">
            <Image
              class="w-56 h-56 rounded-full object-cover ring-4 ring-primary/10 ring-offset-4"
              src={authorImg}
              alt="Douglas Rocha Azevedo"
              width={224}
              height={224}
            />
          </div>
          <div class="flex-1 text-center md:text-left">
            <h3 class="text-2xl md:text-3xl font-bold text-primary mb-2">Douglas Rocha Azevedo</h3>
            <p class="text-secondary font-semibold uppercase tracking-wider text-sm mb-6">Fundador & Especialista em Air Fryer</p>
            <p class="font-body text-on-surface-variant leading-relaxed mb-6">
              Douglas é o fundador do Guia de Air Fryer, um entusiasta de culinária prática e tecnologia que busca traduzir especificações técnicas complexas em recomendações práticas para o dia a dia.
            </p>
            <div class="bg-primary/5 p-6 rounded-xl border-l-4 border-primary mb-6">
              <p class="italic text-primary leading-relaxed">
                "Nossa única lealdade é com a verdade. Se um air fryer não entrega o que promete, nós seremos os primeiros a dizer."
              </p>
            </div>
            <div class="flex items-center gap-4 justify-center md:justify-start mb-6">
              <a href="https://instagram.com/guiadeairfryer" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all" aria-label="Instagram">
                <Icon name="mdi:instagram" class="w-5 h-5" />
              </a>
              <a href="https://twitter.com/guiadeairfryer" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all" aria-label="Twitter">
                <Icon name="mdi:twitter" class="w-5 h-5" />
              </a>
              <a href="https://www.youtube.com/@guiadeairfryer" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all" aria-label="YouTube">
                <Icon name="mdi:youtube" class="w-5 h-5" />
              </a>
            </div>
            <a href="/authors/eduardo/" class="inline-flex items-center gap-2 text-primary font-semibold hover:gap-3 transition-all">
              Ver artigos do autor <Icon name="material-symbols:arrow-forward" class="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 px-gutter">
    <div class="max-w-5xl mx-auto bg-primary rounded-3xl p-12 text-center relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-primary-container/30 to-transparent"></div>
      <div class="relative z-10">
        <h2 class="font-headline text-3xl md:text-4xl font-bold text-white mb-6">Pronto para transformar suas refeições?</h2>
        <p class="text-white/80 text-lg mb-10 max-w-2xl mx-auto">Explore nossos reviews detalhados e encontre o air fryer que vai transformar sua cozinha.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a class="bg-white text-primary px-8 py-4 rounded-xl font-bold hover:bg-slate-100 transition-colors active:scale-95" href="/blog/">Ver Últimos Reviews</a>
          <a class="border border-white/30 text-white px-8 py-4 rounded-xl font-bold hover:bg-white/10 transition-colors active:scale-95" href="/categorias/">Explorar Categorias</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
