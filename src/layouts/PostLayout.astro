---
import { getEntry, getEntries } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Layout from '@layouts/Layout.astro';
import { formatDate } from '@utils/date';
import PostHeadings from '@layouts/components/table-of-contents/PostHeadings.astro';
import RelatedPosts from '@layouts/components/blog/RelatedPosts.astro';
import SocialShare from '@layouts/components/blog/SocialShare.astro';
import ReadingProgress from '@layouts/components/blog/ReadingProgress.astro';
import Breadcrumb from '@layouts/components/common/Breadcrumb.astro';
import { slugify } from '@config/categories';

const { post, headings } = Astro.props;
const { title, meta_title, description, image, date, categories, authors, tags, series } = post.data;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog/' },
  ...(categories?.length ? [{ name: categories[0], url: `/${slugify(categories[0])}/` }] : []),
  { name: title, url: canonicalURL }
];


// Get author details
const authorEntries = authors && authors.length > 0 ? await getEntries(authors.map(id => ({ collection: 'authors', id }))) : [];
const primaryAuthorName = authorEntries.length > 0 ? authorEntries[0].data.title : (authors?.[0] || 'Admin');

let AuthorContent = null;
if (authorEntries.length > 0) {
  const { Content } = await authorEntries[0].render();
  AuthorContent = Content;
}
---

<Layout
  title={meta_title || title}
  description={description}
  image={image?.src}
  article={true}
  canonical={canonicalURL}
  publishDate={date}
  author={authors?.[0] ? { name: primaryAuthorName } : undefined}
  tags={tags}
  categories={categories}
  breadcrumbs={breadcrumbs}
  wideContent={true}
  noTopPadding={true}
>
  <ReadingProgress />

  <!-- Post Header -->
  <section class="max-w-7xl mx-auto px-4 sm:px-8 pt-24 md:pt-32 pb-8">
    <div class="max-w-[840px]">
      <nav class="flex items-center gap-2 text-sm font-medium text-on-surface-variant pb-4">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <Icon name="material-symbols:chevron-right" class="w-4 h-4" />
        <a href="/blog/" class="hover:text-primary transition-colors">Blog</a>
        <Icon name="material-symbols:chevron-right" class="w-4 h-4" />
        <span class="text-on-surface-variant/60 line-clamp-1">{title}</span>
      </nav>
      <h1 class="font-headline text-4xl md:text-5xl lg:text-[3rem] font-extrabold text-primary dark:text-primary-fixed-dim mb-6 leading-tight tracking-tight">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-0 mb-8">
        {authorEntries.length > 0 && (
          <div class="w-12 h-12 rounded-full bg-surface-container-low overflow-hidden border-2 border-surface-container-lowest shadow-sm shrink-0 mr-4">
            {authorEntries[0].data.image ? (
              <Image src={authorEntries[0].data.image} alt={authorEntries[0].data.title} width={48} height={48} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <Icon name="material-symbols:person" class="w-6 h-6 text-on-surface-variant" />
              </div>
            )}
          </div>
        )}
        {authorEntries.length > 0 && (
          <div class="flex flex-col justify-center pr-6 mr-6 border-r border-outline-variant/20">
            <span class="text-[10px] font-medium uppercase tracking-[0.15em] text-on-surface-variant/50 mb-0.5">Autor</span>
            <span class="text-sm font-semibold text-on-surface dark:text-on-surface">{primaryAuthorName}</span>
          </div>
        )}
        {date && (
          <div class="flex flex-col justify-center pr-6 mr-6 border-r border-outline-variant/20">
            <span class="text-[10px] font-medium uppercase tracking-[0.15em] text-on-surface-variant/50 mb-0.5">Publicado em</span>
            <time datetime={date.toISOString()} class="text-sm font-semibold text-on-surface dark:text-on-surface">{formatDate(date)}</time>
          </div>
        )}
        {categories?.length > 0 && (
          <div class="flex flex-col justify-center">
            <span class="text-[10px] font-medium uppercase tracking-[0.15em] text-on-surface-variant/50 mb-0.5">Categoria</span>
            <span class="text-sm font-bold text-primary dark:text-primary-fixed-dim">{categories.join(', ')}</span>
          </div>
        )}
      </div>
    </div>
    <div class="w-full h-[320px] md:h-[480px] rounded-xl overflow-hidden shadow-xl shadow-primary/5">
      {image ? (
        <Image
          src={image}
          alt={title}
          class="w-full h-full object-cover"
          width={1920}
          height={1080}
          widths={[640, 960, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : (
        <div class="w-full h-full bg-surface-container flex items-center justify-center">
          <Icon name="material-symbols:image" class="w-16 h-16 text-on-surface-variant/30" />
        </div>
      )}
    </div>
  </section>

  <article class="max-w-4xl mx-auto px-4 sm:px-8 py-6 space-y-12">

    {headings && headings.length > 0 && (
      <PostHeadings headings={headings} />
    )}

    <div class="prose prose-lg dark:prose-invert prose-brand max-w-none">
      <slot />
    </div>



    <!-- Author Bio -->
    {authorEntries.length > 0 && authorEntries[0].data.description && (
      <div class="flex flex-col md:flex-row items-center gap-8 bg-surface-container p-8 rounded-sm border border-outline-variant/20 mt-16">
        <div class="w-20 h-20 rounded-full bg-surface-container-low flex items-center justify-center shrink-0">
          {authorEntries[0].data.image ? (
            <Image src={authorEntries[0].data.image} alt={authorEntries[0].data.title} width={80} height={80} class="rounded-full object-cover w-full h-full" />
          ) : (
            <Icon name="mdi:account" class="w-10 h-10 text-primary" />
          )}
        </div>
        <div>
          <h2 class="font-headline text-lg font-bold mb-1 text-on-surface">Sobre {authorEntries[0].data.title}</h2>
          <div class="text-on-surface-variant text-sm leading-relaxed font-body">
            {AuthorContent ? <AuthorContent /> : authorEntries[0].data.description}
          </div>
        </div>
      </div>
    )}

    <SocialShare title={title} description={description} url={canonicalURL} />
  </article>

  <!-- Related Posts -->
  <section class="bg-surface-container py-24 mb-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">
      <div class="flex justify-between items-end mb-12">
        <h3 class="font-headline text-3xl md:text-4xl">Leituras Recomendadas</h3>
        <a class="font-label text-sm uppercase tracking-widest text-secondary border-b-2 border-secondary pb-1" href="/blog/">
          Ver todos
        </a>
      </div>
      <RelatedPosts currentPost={post} />
    </div>
  </section>
</Layout>
