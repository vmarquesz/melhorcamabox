---
import Layout from "@layouts/Layout.astro";
import { siteConfig } from "@config/site";
import { Image } from "astro:assets";
import { Icon } from 'astro-icon/components';
import heroImg from "../assets/images/hero-sobre.webp";
import labImg from "../assets/images/lab-testes.webp";
import founderImg from "../assets/images/authors/thiago-lima.webp";

const title = "Sobre Nós";
const description = "Conheça a história e os valores por trás do Guia de Colchão.";
---

<Layout
  title={`${title} | ${siteConfig.title}`}
  description={description}
  wideContent={true}
  noTopPadding={true}
>
  <main class="bg-background text-on-surface font-body">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-32 md:pb-48 overflow-hidden">
      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="max-w-3xl">
          <span class="inline-block px-4 py-1.5 mb-6 rounded-full bg-secondary-fixed text-on-secondary-fixed text-xs font-bold font-label tracking-widest uppercase">
            A Nossa História
          </span>
          <h1 class="text-6xl md:text-8xl font-headline font-extrabold text-primary leading-[0.9] tracking-tighter mb-8">
            Documentando o sono de qualidade.
          </h1>
          <p class="text-xl text-on-surface-variant leading-relaxed mb-12 max-w-2xl italic font-light">
            O Guia de Colchão nasceu da necessidade de transformar a complexidade do mercado de colchões em clareza editorial para o seu descanso.
          </p>
        </div>
      </div>
      <div class="absolute top-0 right-0 w-full md:w-1/2 h-full -z-0 bg-surface-container-low rounded-bl-[120px] overflow-hidden opacity-20 md:opacity-100">
        <Image 
          class="w-full h-full object-cover opacity-90 brightness-[0.9] transition-transform duration-1000 hover:scale-105" 
          src={heroImg} 
          alt="Colchão premium em design minimalista"
        />
      </div>
    </section>

    <!-- Mission & Ethics (Bento Style) -->
    <section class="py-24 bg-surface">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
          <!-- Nossa Missão -->
          <div class="md:col-span-7 bg-surface-container-lowest dark:bg-surface-container-high/50 p-12 rounded-2xl shadow-[0px_4px_24px_rgba(13,30,37,0.04)]">
            <Icon name="material-symbols:target" class="w-9 h-9 text-primary" />
            <h2 class="text-4xl font-headline font-bold text-primary dark:text-primary-fixed-dim mb-6">Nossa Missão</h2>
            <p class="text-lg text-on-surface-variant leading-relaxed">
              Nossa missão é simples, mas tecnicamente rigorosa: democratizar o acesso a informações de qualidade sobre colchões e sono. No Guia de Colchão, não apenas listamos características; analisamos a firmeza, os materiais, a durabilidade e o real conforto que cada modelo entrega. Queremos que cada leitor encontre o colchão perfeito para noites bem dormidas.
            </p>
          </div>
          <!-- Trust Stat -->
          <div class="md:col-span-5 bg-primary-container p-12 rounded-2xl flex flex-col justify-center text-on-primary shadow-xl">
            <div class="text-6xl md:text-7xl font-headline font-black mb-2">500+</div>
            <div class="text-xl font-label text-on-primary-container">Modelos Avaliados</div>
            <p class="mt-4 text-sm opacity-80">Testes rigorosos de firmeza, suporte e durabilidade aplicados a cada colchão_reviewado.</p>
          </div>
          <!-- Transparência Editorial -->
          <div class="md:col-span-12 bg-surface-container-low dark:bg-surface-container-high/30 p-12 rounded-2xl grid md:grid-cols-2 gap-12 items-center">
            <div>
              <h2 class="text-4xl font-headline font-bold text-primary dark:text-primary-fixed-dim mb-6">Transparência Editorial</h2>
              <p class="text-lg text-on-surface-variant leading-relaxed mb-6">
                A confiança é o nosso alicerce mais sólido. No Guia de Colchão, mantemos uma separação total entre nossa equipe de testes e parcerias comerciais.
              </p>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <Icon name="material-symbols:check-circle" class="w-5 h-5 text-primary dark:text-primary-fixed-dim" />
                  <span class="font-bold text-primary dark:text-primary-fixed-dim">Testes Práticos Reais:</span> 
                  <span class="text-on-surface-variant">Mínimo de 30 dias de uso contínuo por review.</span>
                </li>
                <li class="flex items-start gap-3">
                  <Icon name="material-symbols:check-circle" class="w-5 h-5 text-primary dark:text-primary-fixed-dim" />
                  <span class="font-bold text-primary dark:text-primary-fixed-dim">Independência de Marca:</span> 
                  <span class="text-on-surface-variant">Nenhuma marca dita o resultado de nossas análises.</span>
                </li>
              </ul>
            </div>
            <div class="relative aspect-video rounded-2xl overflow-hidden shadow-2xl">
              <Image class="w-full h-full object-cover" src={labImg} alt="Laboratório de testes de colchões" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Founder Bio -->
    <section class="py-24 bg-surface-container-low dark:bg-surface-container-high/30">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row items-center gap-16 lg:gap-24">
          <div class="w-full md:w-1/3">
            <div class="relative">
              <div class="absolute -top-4 -left-4 w-24 h-24 bg-tertiary-fixed rounded-2xl -z-10"></div>
              <Image class="w-full aspect-[4/5] object-cover rounded-2xl shadow-xl transition-transform duration-700 hover:scale-[1.02]" src={founderImg} alt="Thiago Gonçalves Lima - Fundador do Guia de Colchão" />
              <div class="absolute -bottom-6 -right-6 p-6 bg-surface-container-lowest dark:bg-surface-container-high rounded-2xl shadow-2xl">
                <p class="font-headline font-bold text-primary dark:text-primary-fixed-dim text-lg leading-none">Thiago Gonçalves Lima</p>
                <p class="text-[10px] text-on-surface-variant uppercase tracking-widest font-bold mt-2">Fundador & Editor-chefe</p>
              </div>
            </div>
          </div>
          <div class="w-full md:w-2/3">
            <h3 class="text-4xl md:text-5xl font-headline font-bold text-primary dark:text-primary-fixed-dim mb-8 tracking-tighter">Por que confiar em nós?</h3>
            <div class="space-y-6 text-lg text-on-surface-variant leading-relaxed">
              <p>
                Com mais de uma década pesquisando o mercado de colchões e bem-estar, Thiago fundou o Guia de Colchão ao perceber que o mercado estava inundado de promessas de marketing vazias.
              </p>
              <p class="italic">
                "Um colchão não é apenas um móvel; é o investimento mais importante para sua saúde e produtividade. Ele precisa oferecer suporte adequado, conforto térmico e durabilidade real. Se o material cede rápido, o preço barato sai caro. Avaliamos cada detalhe."
              </p>
              <div class="pt-6 flex flex-wrap gap-4">
                <div class="bg-surface-container-highest dark:bg-surface-container-high/80 px-4 py-2 rounded-lg flex items-center gap-2">
                  <Icon name="material-symbols:verified-user" class="w-4 h-4" />
                  <span class="text-sm font-bold font-headline">Expertise em Sono</span>
                </div>
                <div class="bg-surface-container-highest dark:bg-surface-container-high/80 px-4 py-2 rounded-lg flex items-center gap-2">
                  <Icon name="material-symbols:precision-manufacturing" class="w-4 h-4" />
                  <span class="text-sm font-bold font-headline">Critério de Qualidade</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values Banner -->
    <section class="py-24 mb-20 lg:mb-32">
      <div class="max-w-7xl mx-auto px-6">
        <div class="bg-surface-container-lowest dark:bg-surface-container-high/50 rounded-3xl p-12 md:p-20 text-center shadow-[0px_12px_32px_rgba(13,30,37,0.06)] border border-outline-variant/10">
          <h2 class="text-4xl font-headline font-bold text-primary dark:text-primary-fixed-dim mb-16">Nossos Valores Fundamentais</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20">
            <div>
              <div class="text-4xl font-headline font-black text-primary-container dark:text-primary-fixed-dim mb-4 opacity-30">01.</div>
              <h3 class="font-bold text-xl mb-3 text-primary dark:text-primary-fixed-dim">Exatidão</h3>
              <p class="text-sm text-on-surface-variant leading-relaxed">Dados empíricos superam opiniões subjetivas em todos os nossos comparativos de conforto e durabilidade.</p>
            </div>
            <div>
              <div class="text-4xl font-headline font-black text-primary-container dark:text-primary-fixed-dim mb-4 opacity-30">02.</div>
              <h3 class="font-bold text-xl mb-3 text-primary dark:text-primary-fixed-dim">Acessibilidade</h3>
              <p class="text-sm text-on-surface-variant leading-relaxed">Explicamos tecnologias como molas ensacadas, espuma viscoelástica e latex de forma clara e compreensível.</p>
            </div>
            <div>
              <div class="text-4xl font-headline font-black text-primary-container dark:text-primary-fixed-dim mb-4 opacity-30">03.</div>
              <h3 class="font-bold text-xl mb-3 text-primary dark:text-primary-fixed-dim">Integridade</h3>
              <p class="text-sm text-on-surface-variant leading-relaxed">Mantemos nosso selo de total transparência editorial em 100% de nossas recomendações.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
