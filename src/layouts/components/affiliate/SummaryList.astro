---
interface Product {
  title: string;
  image: string;
  link: string;
}

interface Props {
  products: Product[];
}

import { Icon } from 'astro-icon/components';

const { products } = Astro.props;
const safeProducts = Array.isArray(products) && products.length > 0 ? products : [];
---

{safeProducts.length > 0 && (
<section class="summary-list not-prose my-16 space-y-6">
  <div class="flex items-center gap-4 mb-8">
    <div class="w-12 h-12 rounded-2xl bg-primary-container/10 dark:bg-primary-container/20 flex items-center justify-center text-primary dark:text-primary-fixed-dim">
      <Icon name="material-symbols:assignment-turned-in" class="w-7 h-7" />
    </div>
    <h3 class="font-headline text-2xl md:text-3xl font-bold text-primary dark:text-primary-fixed-dim tracking-tight">
      Resumo dos Melhores Modelos
    </h3>
  </div>
  
  <div class="space-y-4">
    {safeProducts.map((item, index) => (
      <div class="flex flex-row items-center gap-2 sm:gap-4 md:gap-8 p-3 sm:p-4 md:p-6 bg-surface-container-lowest dark:bg-surface-container-high/50 rounded-xl border border-outline-variant/10 dark:border-outline-variant/10 shadow-[0px_4px_20px_rgba(30,58,138,0.04)] dark:shadow-[0px_4px_20px_rgba(0,0,0,0.3)] hover:shadow-xl hover:border-primary/20 dark:hover:border-primary-container/40 transition-all duration-300">
        <span class="text-base sm:text-xl md:text-2xl font-bold font-headline text-primary/20 dark:text-primary-fixed-dim/20 shrink-0 w-4 sm:w-8 md:w-10 text-center tracking-tight">
          {index + 1}
        </span>
        
        <a href={item.link} target="_blank" rel="nofollow sponsored" class="w-10 h-10 sm:w-16 sm:h-16 md:w-20 md:h-20 bg-white rounded-xl flex items-center justify-center p-1.5 sm:p-2 shrink-0 shadow-sm hover:shadow-md transition-all">
          <img 
            src={item.image} 
            alt={item.title} 
            width="80"
            height="80"
            class="max-h-full object-contain" 
            loading="lazy"
          />
        </a>
        
        <div class="grow text-left min-w-0">
          <a href={item.link} target="_blank" rel="nofollow sponsored">
            <h4 class="font-headline font-bold text-[13px] sm:text-base md:text-xl text-on-surface dark:text-on-surface hover:text-primary dark:hover:text-primary-fixed-dim transition-colors line-clamp-2 md:line-clamp-3 leading-tight">
              {item.title}
            </h4>
          </a>
        </div>
        
        <a 
          href={item.link} 
          target="_blank" 
          rel="nofollow sponsored" 
          class="bg-primary dark:bg-primary-container text-on-primary dark:text-on-primary-container px-3 py-2 sm:px-4 sm:py-2.5 md:px-8 md:py-4 rounded-lg font-bold font-headline hover:bg-primary-container dark:hover:bg-primary-fixed hover:text-on-primary dark:hover:text-on-primary-fixed transition-all text-[9px] sm:text-[10px] md:text-xs uppercase tracking-widest whitespace-nowrap shrink-0 shadow-sm hover:shadow-lg"
        >
          Ver Preço
        </a>
      </div>
    ))}
  </div>
</section>
)}
