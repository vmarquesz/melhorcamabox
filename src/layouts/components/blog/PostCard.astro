---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { formatDate } from '@utils/date';
import { slugify } from '@config/categories';

const { post, horizontal = false } = Astro.props;
const { title, description, image, date, categories, authors, series } = post.data;

const formatCategoryLabel = (category: string) => {
  // Preserve labels that already have custom casing from existing content.
  if (category !== category.toLowerCase()) return category;
  return category
    .split(/[\s-]+/)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
};

// Extract the slug from the canonical URL or use the file name
const slug = post.data.canonical 
  ? new URL(post.data.canonical).pathname.split('/').filter(Boolean).pop()
  : post.slug;

// Check if post is part of a series
const isPartOfSeries = series && Array.isArray(series) && series.length === 2;

// Get author details
const authorEntry = authors && authors.length > 0 ? await getEntry('authors', authors[0]) : null;
const authorName = authorEntry ? authorEntry.data.title : (authors?.[0] || 'Admin');
---

{horizontal ? (
  <a href={`/${slug}/`} class="group flex flex-col sm:flex-row bg-surface-container-low dark:bg-white/5 rounded-[2.5rem] overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-500 h-full border border-outline-variant/10">
    <div class="sm:w-2/5 aspect-[4/3] sm:aspect-auto sm:h-full relative overflow-hidden bg-surface-variant/50 p-2">
      <div class="w-full h-full relative rounded-[2rem] overflow-hidden shadow-inner">
        {image ? (
          <Image src={image} alt={title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" width={400} height={300} widths={[400, 640, 800]} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw" loading="lazy" decoding="async" />
        ) : (
          <div class="absolute inset-0 flex items-center justify-center bg-surface-container text-on-surface-variant">
            <Icon name="material-symbols:image" class="w-9 h-9 opacity-20" />
          </div>
        )}
        {categories && categories.length > 0 && (
          <div class="absolute top-4 left-4 z-10">
            <span class="bg-primary text-on-primary text-[10px] font-bold px-3 py-1 rounded-lg uppercase tracking-widest shadow-xl font-headline">{formatCategoryLabel(categories[0])}</span>
          </div>
        )}
      </div>
    </div>
    <div class="sm:w-3/5 p-8 flex flex-col justify-center">
      <h3 class="font-headline text-2xl font-black text-on-surface mb-4 leading-tight group-hover:text-primary transition-colors line-clamp-3 tracking-tighter italic">
        {title}
      </h3>
      {description && (
        <p class="font-body text-base text-on-surface-variant line-clamp-2 md:line-clamp-3 mb-6 leading-relaxed">
          {description}
        </p>
      )}
      <div class="mt-auto">
         <span class="inline-block font-headline text-[10px] font-bold px-6 py-2.5 bg-primary-container text-on-primary-container rounded-xl uppercase tracking-widest shadow-sm group-hover:shadow-lg transition-all">
           Análise Completa
         </span>
      </div>
    </div>
  </a>
) : (
  <article class="flex flex-col group h-full">
    <a href={`/${slug}/`} class="relative mb-6 overflow-hidden rounded-[2.5rem] aspect-[16/10] bg-surface-container-low block shadow-lg hover:shadow-2xl transition-all duration-500">
      {image ? (
        <Image src={image} alt={title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" width={640} height={400} widths={[400, 640, 800]} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw" loading="lazy" decoding="async" />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-surface-container text-on-surface-variant">
          <Icon name="material-symbols:image" class="w-14 h-14 opacity-20" />
        </div>
      )}
      {categories && categories.length > 0 && (
        <div class="absolute top-4 left-4 z-10">
          <span class="bg-primary text-on-primary text-[10px] font-bold px-3 py-1 rounded-lg uppercase tracking-widest shadow-xl font-headline">{formatCategoryLabel(categories[0])}</span>
        </div>
      )}
    </a>
    
    <h3 class="font-headline text-2xl font-black text-on-surface mb-4 group-hover:text-primary transition-colors line-clamp-2 tracking-tighter italic">
      <a href={`/${slug}/`}>{title}</a>
    </h3>
    
    {description && (
      <p class="font-body text-base text-on-surface-variant leading-relaxed mb-6 line-clamp-3">
        {description}
      </p>
    )}
    
    <div class="mt-auto flex items-center justify-between border-t border-outline-variant/10 pt-4">
      <a href={`/${slug}/`} class="font-black font-headline text-[10px] uppercase tracking-widest text-primary hover:text-primary-container transition-colors italic">Explorar Review</a>
      {date && (
        <span class="font-headline text-[10px] font-bold text-on-surface-variant/50 flex items-center gap-2 uppercase tracking-[0.2em]">
          <Icon name="material-symbols:calendar-today" class="w-3 h-3" />
          {formatDate(date)}
        </span>
      )}
    </div>
  </article>
)}
